<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_odfe_employee_tree" model="ir.ui.view">
    <field name="name">odfe.employee.tree</field>
    <field name="model">odfe.employee</field>
    <field name="arch" type="xml">
      <tree>
        <field name="name"/>
        <field name="role"/>
        <field name="phone"/>
        <field name="email"/>
        <field name="user_id"/>
        <field name="active"/>
      </tree>
    </field>
  </record>

  <record id="view_odfe_employee_form" model="ir.ui.view">
    <field name="name">odfe.employee.form</field>
    <field name="model">odfe.employee</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <div class="oe_button_box" name="button_box">
            <button name="toggle_active" type="object"
                    class="oe_stat_button" icon="fa-archive">
              <field name="active" widget="boolean_toggle"/>
            </button>
          </div>
          <div class="oe_title">
            <h1>
              <field name="name" placeholder="Employee name..."/>
            </h1>
          </div>
          <group>
            <group string="Contact Information">
              <field name="phone" placeholder="Phone number"/>
              <field name="email" placeholder="Email address"/>
            </group>
            <group string="ODFE Settings">
              <field name="role" widget="selection"/>
              <field name="pin" password="True"/>
              <field name="user_id" options="{'no_create': True}"/>
            </group>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_odfe_employee_search" model="ir.ui.view">
    <field name="name">odfe.employee.search</field>
    <field name="model">odfe.employee</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="phone"/>
        <field name="email"/>
        <filter name="group_active" string="Active" domain="[('active','=',True)]"/>
        <separator/>
        <filter name="role_admin" string="Admin" domain="[('role','=','admin')]"/>
        <filter name="role_manager" string="Manager" domain="[('role','=','manager')]"/>
        <filter name="role_cashier" string="Cashier" domain="[('role','=','cashier')]"/>
        <filter name="role_kitchen" string="Kitchen" domain="[('role','=','kitchen')]"/>
        <filter name="role_waiter" string="Waiter" domain="[('role','=','waiter')]"/>
        <group expand="0" string="Group By">
          <filter name="group_by_role" string="Role" context="{'group_by': 'role'}"/>
          <filter name="group_by_active" string="Active" context="{'group_by': 'active'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="view_odfe_employee_kanban" model="ir.ui.view">
    <field name="name">odfe.employee.kanban</field>
    <field name="model">odfe.employee</field>
    <field name="arch" type="xml">
      <kanban class="o_kanban_mobile">
        <field name="name"/>
        <field name="role"/>
        <field name="active"/>
        <templates>
          <t t-name="kanban-box">
            <div class="oe_kanban_global_click">
              <div class="o_kanban_image">
                <img t-att-src="kanban_image('odfe.employee', 'name', record.id.raw_value)" alt="Employee" style="width:64px; height:64px; border-radius:50%;"/>
              </div>
              <div class="oe_kanban_details">
                <strong class="o_kanban_record_title">
                  <field name="name"/>
                </strong>
                <div class="o_kanban_record_subtitle">
                  <field name="role"/>
                </div>
                <div class="o_kanban_record_subtitle">
                  <field name="email"/>
                </div>
              </div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <record id="action_odfe_employee" model="ir.actions.act_window">
    <field name="name">Employees</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">odfe.employee</field>
    <field name="view_mode">tree,form,kanban</field>
    <field name="search_view_id" ref="view_odfe_employee_search"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Create a new employee
      </p>
      <p>
        Manage restaurant employees and link them to Odoo users.
      </p>
    </field>
  </record>
</odoo>
