<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ODFE Cafe POS — Standalone Login Page Template
         Usage:  <t t-call="odfe_auth.login_page"/>
         Route:  /odfe/login
         ═══════════════════════════════════════════════════════════════════════ -->

    <template id="login_page" name="ODFE Login Page">
        <t t-call="web.html_container">

            <!-- ── Stylesheets ──────────────────────────────────────────── -->
            <head>
                <meta charset="UTF-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <title>ODFE Cafe POS — Sign In</title>
                <link rel="icon" type="image/svg+xml" href="/odfe_auth/static/src/img/favicon.svg"/>

                <t t-call="web.frontend_layout"/>

                <style>
                    /* ── ODFE CSS Variables (inline fallback) ──────────── */
                    :root {
                        --odfe-primary: #32D26B;
                        --odfe-accent: #22C55E;
                        --odfe-danger: #EF4444;
                        --odfe-danger-light: rgba(239, 68, 68, 0.12);
                        --odfe-bg-deep: #0B1117;
                        --odfe-glass-border: rgba(255, 255, 255, 0.08);
                        --odfe-glass-border-hover: rgba(255, 255, 255, 0.14);
                        --odfe-text-primary: #F1F5F9;
                        --odfe-text-secondary: #94A3B8;
                        --odfe-text-tertiary: #64748B;
                        --odfe-text-muted: #475569;
                        --odfe-text-sm: 0.875rem;
                        --odfe-text-md: 1rem;
                        --odfe-text-2xl: 1.75rem;
                        --odfe-text-3xl: 2.25rem;
                        --odfe-font-heading: 'Inter', system-ui, sans-serif;
                        --odfe-space-1: 0.25rem;
                        --odfe-space-2: 0.5rem;
                        --odfe-space-3: 0.75rem;
                        --odfe-space-4: 1rem;
                        --odfe-space-5: 1.25rem;
                        --odfe-space-6: 1.5rem;
                        --odfe-space-8: 2rem;
                        --odfe-space-10: 2.5rem;
                        --odfe-radius-lg: 12px;
                        --odfe-radius-xl: 16px;
                        --odfe-radius-2xl: 20px;
                        --odfe-radius-md: 8px;
                    }

                    /* ── Reset ────────────────────────────────────────── */
                    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
                    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; background: var(--odfe-bg-deep); color: var(--odfe-text-primary); -webkit-font-smoothing: antialiased; }

                    /* ── Layout ───────────────────────────────────────── */
                    .odfe-login {
                        min-height: 100vh;
                        display: grid;
                        grid-template-columns: 1fr 1fr;
                    }
                    @media (max-width: 768px) { .odfe-login { grid-template-columns: 1fr; } }

                    /* ── Left Visual Panel ────────────────────────────── */
                    .odfe-login__visual {
                        position: relative;
                        display: flex; align-items: center; justify-content: center;
                        overflow: hidden;
                        background: linear-gradient(135deg, #0D1B20, #132D35, #32D26B);
                    }
                    @media (max-width: 768px) { .odfe-login__visual { display: none; } }

                    .odfe-login__visual::before {
                        content: '';
                        position: absolute; inset: 0;
                        background:
                            radial-gradient(ellipse 400px 400px at 30% 50%, rgba(50, 210, 107, 0.2) 0%, transparent 60%),
                            radial-gradient(ellipse 300px 300px at 70% 30%, rgba(214, 167, 79, 0.1) 0%, transparent 60%);
                    }

                    .odfe-login__visual-content {
                        position: relative; z-index: 1;
                        text-align: center;
                        padding: 2rem;
                    }

                    .odfe-login__visual-icon { font-size: 80px; margin-bottom: 1.5rem; opacity: 0.8; }

                    .odfe-login__visual-title {
                        font-family: var(--odfe-font-heading);
                        font-size: var(--odfe-text-3xl);
                        font-weight: 800;
                        margin-bottom: 0.75rem;
                    }

                    .odfe-login__visual-subtitle {
                        color: var(--odfe-text-secondary);
                        font-size: var(--odfe-text-md);
                        max-width: 340px;
                        margin: 0 auto;
                    }

                    /* ── Right Form Panel ─────────────────────────────── */
                    .odfe-login__form-side {
                        display: flex; align-items: center; justify-content: center;
                        background: var(--odfe-bg-deep);
                        padding: 2rem;
                        position: relative;
                    }

                    .odfe-login__form-side::before {
                        content: '';
                        position: absolute; inset: 0;
                        background: radial-gradient(ellipse 400px 300px at 50% 40%, rgba(50, 210, 107, 0.06) 0%, transparent 60%);
                    }

                    /* ── Glass Card ───────────────────────────────────── */
                    .odfe-login__card {
                        background: rgba(255, 255, 255, 0.04);
                        backdrop-filter: blur(28px);
                        -webkit-backdrop-filter: blur(28px);
                        border: 1px solid var(--odfe-glass-border);
                        border-radius: var(--odfe-radius-2xl);
                        padding: 2.5rem;
                        width: 100%;
                        max-width: 420px;
                        position: relative; z-index: 1;
                        animation: odfe-scaleIn 400ms ease-out;
                    }

                    @keyframes odfe-scaleIn {
                        from { opacity: 0; transform: scale(0.96) translateY(8px); }
                        to   { opacity: 1; transform: scale(1) translateY(0); }
                    }

                    /* ── Logo ────────────────────────────────────────── */
                    .odfe-login__logo { text-align: center; margin-bottom: 2rem; }

                    .odfe-login__logo-icon {
                        width: 56px; height: 56px;
                        border-radius: var(--odfe-radius-lg);
                        background: linear-gradient(135deg, var(--odfe-primary), var(--odfe-accent));
                        display: flex; align-items: center; justify-content: center;
                        margin: 0 auto 1rem;
                        color: white;
                        font-size: 24px; font-weight: 800;
                    }

                    .odfe-login__logo h1 {
                        font-size: var(--odfe-text-2xl);
                        background: linear-gradient(135deg, #32D26B, #22C55E);
                        -webkit-background-clip: text;
                        -webkit-text-fill-color: transparent;
                        background-clip: text;
                    }

                    .odfe-login__logo p {
                        font-size: var(--odfe-text-sm);
                        color: var(--odfe-text-tertiary);
                        margin-top: var(--odfe-space-1);
                    }

                    /* ── Google Button ────────────────────────────────── */
                    .odfe-login__google {
                        display: flex; align-items: center; justify-content: center;
                        width: 100%;
                        background: rgba(255, 255, 255, 0.08);
                        border: 1px solid var(--odfe-glass-border);
                        color: var(--odfe-text-primary);
                        margin-bottom: 1.5rem;
                        border-radius: var(--odfe-radius-lg);
                        font-weight: 500;
                        gap: 0.75rem;
                        padding: 0.75rem 1rem;
                        cursor: pointer;
                        transition: all 0.2s ease;
                        font-size: 0.95rem;
                    }

                    .odfe-login__google:hover {
                        background: rgba(255, 255, 255, 0.12);
                        border-color: var(--odfe-glass-border-hover);
                    }

                    .odfe-login__google img { width: 20px; height: 20px; }

                    /* ── Divider ─────────────────────────────────────── */
                    .odfe-login__divider {
                        display: flex; align-items: center;
                        gap: 1rem;
                        margin-bottom: 1.5rem;
                        color: var(--odfe-text-muted);
                        font-size: var(--odfe-text-sm);
                    }

                    .odfe-login__divider::before,
                    .odfe-login__divider::after {
                        content: '';
                        flex: 1;
                        height: 1px;
                        background: var(--odfe-glass-border);
                    }

                    /* ── Fields ──────────────────────────────────────── */
                    .odfe-login__field { margin-bottom: 1.25rem; }

                    .odfe-login__field label {
                        display: block;
                        font-size: var(--odfe-text-sm);
                        font-weight: 500;
                        color: var(--odfe-text-secondary);
                        margin-bottom: 0.5rem;
                    }

                    .odfe-login__field input {
                        width: 100%;
                        height: 48px;
                        background: rgba(255, 255, 255, 0.04);
                        border: 1px solid var(--odfe-glass-border);
                        border-radius: var(--odfe-radius-lg);
                        padding: 0 1rem;
                        color: var(--odfe-text-primary);
                        font-size: 0.95rem;
                        transition: all 0.2s ease;
                        outline: none;
                    }

                    .odfe-login__field input::placeholder { color: var(--odfe-text-muted); }

                    .odfe-login__field input:focus {
                        border-color: var(--odfe-primary);
                        box-shadow: 0 0 0 3px rgba(50, 210, 107, 0.15);
                        background: rgba(255, 255, 255, 0.06);
                    }

                    /* ── Options Row ─────────────────────────────────── */
                    .odfe-login__options {
                        display: flex; align-items: center; justify-content: space-between;
                        margin-bottom: 1.5rem;
                        font-size: var(--odfe-text-sm);
                        color: var(--odfe-text-secondary);
                    }

                    .odfe-login__options label {
                        display: flex; align-items: center;
                        gap: 0.5rem;
                        cursor: pointer;
                    }

                    .odfe-login__options input[type="checkbox"] {
                        width: 16px; height: 16px;
                        accent-color: var(--odfe-primary);
                        cursor: pointer;
                    }

                    .odfe-login__options a {
                        color: var(--odfe-primary);
                        text-decoration: none;
                        transition: opacity 0.2s;
                    }

                    .odfe-login__options a:hover { opacity: 0.8; }

                    /* ── Submit Button ────────────────────────────────── */
                    .odfe-login__submit {
                        display: flex; align-items: center; justify-content: center;
                        width: 100%;
                        padding: 1rem;
                        background: linear-gradient(135deg, var(--odfe-primary), var(--odfe-accent));
                        color: white;
                        font-size: var(--odfe-text-md);
                        font-weight: 600;
                        border: none;
                        border-radius: var(--odfe-radius-lg);
                        cursor: pointer;
                        transition: all 0.2s ease;
                        position: relative;
                        overflow: hidden;
                    }

                    .odfe-login__submit:hover {
                        box-shadow: 0 0 20px rgba(50, 210, 107, 0.35);
                        transform: translateY(-1px);
                    }

                    .odfe-login__submit:active { transform: translateY(0); }

                    .odfe-login__submit--loading .odfe-login__submit-text { opacity: 0; }
                    .odfe-login__submit--loading .odfe-login__submit-spinner { display: block; }

                    .odfe-login__submit-spinner {
                        display: none;
                        position: absolute;
                        width: 22px; height: 22px;
                        border: 3px solid rgba(255, 255, 255, 0.3);
                        border-top-color: white;
                        border-radius: 50%;
                        animation: odfe-spin 0.6s linear infinite;
                    }

                    @keyframes odfe-spin { to { transform: rotate(360deg); } }

                    /* ── Error Message ────────────────────────────────── */
                    .odfe-login__error {
                        color: var(--odfe-danger);
                        font-size: var(--odfe-text-sm);
                        margin-bottom: 1rem;
                        padding: 0.75rem;
                        background: var(--odfe-danger-light);
                        border-radius: var(--odfe-radius-md);
                        display: none;
                    }

                    .odfe-login__error--visible { display: block; }

                    /* ── Demo Hint ────────────────────────────────────── */
                    .odfe-login__hint {
                        text-align: center;
                        margin-top: 1.5rem;
                        font-size: 0.8rem;
                        color: var(--odfe-text-muted);
                    }

                    .odfe-login__hint code {
                        background: rgba(50, 210, 107, 0.1);
                        color: var(--odfe-primary);
                        padding: 0.15em 0.45em;
                        border-radius: 4px;
                        font-size: 0.85em;
                    }
                </style>
            </head>

            <!-- ── Body ────────────────────────────────────────────────── -->
            <body>

                <div class="odfe-login">

                    <!-- ═══════════════════════════════════════════════════
                         LEFT PANEL — Visual Branding
                         ═══════════════════════════════════════════════════ -->
                    <div class="odfe-login__visual">
                        <div class="odfe-login__visual-content">
                            <div class="odfe-login__visual-icon">☕</div>
                            <h2 class="odfe-login__visual-title">Premium Cafe POS</h2>
                            <p class="odfe-login__visual-subtitle">
                                Designed for modern cafes and restaurants
                            </p>
                        </div>
                    </div>

                    <!-- ═══════════════════════════════════════════════════
                         RIGHT PANEL — Login Form
                         ═══════════════════════════════════════════════════ -->
                    <div class="odfe-login__form-side">

                        <div class="odfe-login__card">

                            <!-- ── Logo ──────────────────────────────────── -->
                            <div class="odfe-login__logo">
                                <div class="odfe-login__logo-icon">O</div>
                                <h1>ODFE</h1>
                                <p>Cafe Point of Sale</p>
                            </div>

                            <!-- ── Error Area ────────────────────────────── -->
                            <div class="odfe-login__error" id="odfeLoginError"></div>

                            <!-- ── Welcome Title ─────────────────────────── -->
                            <div style="text-align:center; margin-bottom:1.5rem;">
                                <h2 style="font-size:1.35rem; font-weight:700; margin-bottom:0.35rem;">Welcome Back</h2>
                                <p style="font-size:var(--odfe-text-sm); color:var(--odfe-text-tertiary);">Sign in to your POS terminal</p>
                            </div>

                            <!-- ── Google Sign-In ────────────────────────── -->
                            <button type="button" class="odfe-login__google" id="odfeGoogleBtn">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                                </svg>
                                Continue with Google
                            </button>

                            <!-- ── Divider ───────────────────────────────── -->
                            <div class="odfe-login__divider">or continue with email</div>

                            <!-- ── Login Form ────────────────────────────── -->
                            <form id="odfeLoginForm" autocomplete="on" novalidate="novalidate">

                                <!-- Email -->
                                <div class="odfe-login__field">
                                    <label for="odfeEmail">Email Address</label>
                                    <input type="email" id="odfeEmail" name="login"
                                        placeholder="you@example.com"
                                        required="required"
                                        autocomplete="email"/>
                                </div>

                                <!-- Password -->
                                <div class="odfe-login__field">
                                    <label for="odfePassword">Password</label>
                                    <input type="password" id="odfePassword" name="password"
                                        placeholder="Enter your password"
                                        required="required"
                                        autocomplete="current-password"/>
                                </div>

                                <!-- Options Row -->
                                <div class="odfe-login__options">
                                    <label>
                                        <input type="checkbox" name="remember" id="odfeRemember"/>
                                        Remember me
                                    </label>
                                    <a href="/odfe/reset-password">Forgot password?</a>
                                </div>

                                <!-- Submit -->
                                <button type="submit" class="odfe-login__submit" id="odfeSubmitBtn">
                                    <span class="odfe-login__submit-text">Sign In</span>
                                    <span class="odfe-login__submit-spinner"></span>
                                </button>

                            </form>

                            <!-- ── Demo Hint ─────────────────────────────── -->
                            <div class="odfe-login__hint">
                                Demo credentials: <code>demo@odfe.app</code> / <code>password</code>
                            </div>

                        </div><!-- /.odfe-login__card -->

                    </div><!-- /.odfe-login__form-side -->

                </div><!-- /.odfe-login -->


                <!-- ═══════════════════════════════════════════════════════
                     CLIENT-SIDE FORM HANDLING
                     ═══════════════════════════════════════════════════════ -->
                <script>
                    (function () {
                        'use strict';

                        const form     = document.getElementById('odfeLoginForm');
                        const submitBtn= document.getElementById('odfeSubmitBtn');
                        const errorBox = document.getElementById('odfeLoginError');

                        /**
                         * Display an error message to the user.
                         */
                        function showError(msg) {
                            errorBox.textContent = msg;
                            errorBox.classList.add('odfe-login__error--visible');
                        }

                        /**
                         * Clear any visible error message.
                         */
                        function clearError() {
                            errorBox.textContent = '';
                            errorBox.classList.remove('odfe-login__error--visible');
                        }

                        /**
                         * Toggle the loading spinner on the submit button.
                         */
                        function setLoading(loading) {
                            if (loading) {
                                submitBtn.classList.add('odfe-login__submit--loading');
                                submitBtn.disabled = true;
                            } else {
                                submitBtn.classList.remove('odfe-login__submit--loading');
                                submitBtn.disabled = false;
                            }
                        }

                        /* Prevent default form submit and handle via JS */
                        form.addEventListener('submit', function (e) {
                            e.preventDefault();
                            clearError();

                            const email    = document.getElementById('odfeEmail').value.trim();
                            const password = document.getElementById('odfePassword').value;

                            /* Basic client-side validation */
                            if (!email) {
                                showError('Please enter your email address.');
                                document.getElementById('odfeEmail').focus();
                                return;
                            }
                            if (!password) {
                                showError('Please enter your password.');
                                document.getElementById('odfePassword').focus();
                                return;
                            }

                            /* Show loading state */
                            setLoading(true);

                            /*
                             * ── Authentication logic ────────────────────
                             * Replace the block below with your real auth
                             * call (XMLHttpRequest / fetch / Odoo RPC).
                             *
                             * Example using Odoo's web session:
                             *
                             *   odoo.services.session.authenticate({
                             *       login: email,
                             *       password: password,
                             *   }).then(function (result) {
                             *       if (result) {
                             *           window.location.href = '/odfe/pos';
                             *       } else {
                             *           setLoading(false);
                             *           showError('Invalid email or password.');
                             *       }
                             *   });
                             */

                            /* Simulated network delay for demo */
                            setTimeout(function () {
                                setLoading(false);

                                /* Demo credential check */
                                if (email === 'demo@odfe.app' &amp;&amp; password === 'password') {
                                    window.location.href = '/odfe/pos';
                                } else {
                                    showError('Invalid email or password. Try demo@odfe.app / password');
                                }
                            }, 1200);
                        });

                        /* ── Google sign-in placeholder ─────────────────── */
                        document.getElementById('odfeGoogleBtn').addEventListener('click', function () {
                            showError('Google sign-in is not configured in this demo.');
                        });

                    })();
                </script>

            </body>

        </t>
    </template>

</odoo>
