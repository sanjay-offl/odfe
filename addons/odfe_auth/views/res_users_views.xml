<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_users_form_inherit_odfe" model="ir.ui.view">
    <field name="name">res.users.form.inherit.odfe</field>
    <field name="model">res.users</field>
    <field name="inherit_id" ref="base.view_users_form"/>
    <field name="arch" type="xml">
      <xpath expr="//group[@name='features']" position="after">
        <group string="ODFE Authentication" name="odfe_auth" groups="odfe_auth.odfe_group_admin">
          <field name="odfe_role" widget="selection"/>
          <field name="employee_id" options="{'no_create': True}"/>
          <field name="pos_security_pin" password="True"/>
        </group>
      </xpath>
    </field>
  </record>

  <record id="view_users_tree_inherit_odfe" model="ir.ui.view">
    <field name="name">res.users.tree.inherit.odfe</field>
    <field name="model">res.users</field>
    <field name="inherit_id" ref="base.view_users_tree"/>
    <field name="arch" type="xml">
      <field name="login" position="after">
        <field name="odfe_role" optional="show"/>
      </field>
    </field>
  </record>
</odoo>
