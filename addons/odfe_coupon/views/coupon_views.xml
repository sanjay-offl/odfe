<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odfe_coupon_tree" model="ir.ui.view">
        <field name="name">odfe.coupon.tree</field>
        <field name="model">odfe.coupon</field>
        <field name="arch" type="xml">
            <tree decoration-danger="active==False">
                <field name="code"/>
                <field name="name"/>
                <field name="type"/>
                <field name="value"/>
                <field name="used_count"/>
                <field name="usage_limit"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_odfe_coupon_form" model="ir.ui.view">
        <field name="name">odfe.coupon.form</field>
        <field name="model">odfe.coupon</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object"
                                class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_toggle"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" text="Inactive" bg_color="danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="type"/>
                            <field name="value"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="minimum_order_amount" widget="monetary"/>
                            <field name="maximum_discount" widget="monetary"/>
                            <field name="usage_limit"/>
                            <field name="used_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="customers" string="Customer Restrictions">
                            <field name="customer_ids" nolabel="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="phone"/>
                                    <field name="email"/>
                                </tree>
                            </field>
                        </page>
                        <page name="validity" string="Validity">
                            <group>
                                <field name="start_date"/>
                                <field name="end_date"/>
                            </group>
                        </page>
                        <page name="description" string="Description">
                            <field name="description" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_odfe_coupon_search" model="ir.ui.view">
        <field name="name">odfe.coupon.search</field>
        <field name="model">odfe.coupon</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="expired" string="Expired" domain="[('end_date','&lt;',context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="type_percentage" string="Percentage" domain="[('type','=','percentage')]"/>
                <filter name="type_fixed" string="Fixed Amount" domain="[('type','=','fixed_amount')]"/>
                <filter name="type_free_shipping" string="Free Shipping" domain="[('type','=','free_shipping')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_type" string="Type" context="{'group_by':'type'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
