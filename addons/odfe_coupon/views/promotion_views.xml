<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odfe_promotion_tree" model="ir.ui.view">
        <field name="name">odfe.promotion.tree</field>
        <field name="model">odfe.promotion</field>
        <field name="arch" type="xml">
            <tree decoration-danger="active==False">
                <field name="name"/>
                <field name="type"/>
                <field name="discount_percent"/>
                <field name="discount_amount" widget="monetary"/>
                <field name="min_purchase" widget="monetary"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_odfe_promotion_form" model="ir.ui.view">
        <field name="name">odfe.promotion.form</field>
        <field name="model">odfe.promotion</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object"
                                class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_toggle"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" text="Inactive" bg_color="danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </group>
                    <group string="Conditions">
                        <group>
                            <field name="condition_product_ids" widget="many2many_tags"/>
                            <field name="condition_quantity"/>
                            <field name="min_purchase" widget="monetary"/>
                        </group>
                        <group>
                            <field name="discount_percent" invisible="[('type','not in',('percentage_off','buy_x_get_y'))]"/>
                            <field name="discount_amount" widget="monetary" invisible="[('type','!=','fixed_amount')]"/>
                            <field name="applicable_product_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
