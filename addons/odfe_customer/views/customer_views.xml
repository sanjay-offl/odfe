<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tree View -->
        <record id="view_odfe_customer_tree" model="ir.ui.view">
            <field name="name">odfe.customer.tree</field>
            <field name="model">odfe.customer</field>
            <field name="arch" type="xml">
                <tree string="Customers" multi_edit="1">
                    <field name="image" widget="image" class="oe_avatar" options="{'size': [40, 40]}"/>
                    <field name="name" filterable="1"/>
                    <field name="phone" widget="phone"/>
                    <field name="email" widget="email"/>
                    <field name="city"/>
                    <field name="state_id"/>
                    <field name="total_spent" widget="monetary" sum="Total"/>
                    <field name="visit_count" sum="Total"/>
                    <field name="last_visit"/>
                    <field name="tier" widget="badge" options="{'color': 'info'}"/>
                    <field name="active" invisible="1"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_odfe_customer_form" model="ir.ui.view">
            <field name="name">odfe.customer.form</field>
            <field name="model">odfe.customer</field>
            <field name="arch" type="xml">
                <form string="Customer">
                    <header>
                        <button name="action_view_orders" type="object" string="View Orders"
                                class="oe_highlight" groups="base.group_user"/>
                        <button name="action_enroll_loyalty" type="object" string="Enroll in Loyalty"
                                groups="base.group_user"/>
                        <field name="active" widget="toggle_button"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_orders" type="object"
                                    class="oe_stat_button" icon="fa-shopping-cart"
                                    string="Orders"
                                    context="{'default_partner_id': partner_id}">
                                <div class="o_stat_info">
                                    <field name="visit_count" class="o_stat_text"/>
                                </div>
                            </button>
                            <button name="%(action_odfe_customer_loyalty)d" type="action"
                                    class="oe_stat_button" icon="fa-star"
                                    string="Loyalty">
                                <div class="o_stat_info">
                                    <field name="tier" widget="badge"/>
                                </div>
                            </button>
                        </div>
                        <div class="oe_title">
                            <div class="oe_avatar">
                                <field name="image" widget="image" class="oe_avatar" options="{'size': [192, 192]}"/>
                            </div>
                            <h1>
                                <field name="name" placeholder="Customer Name"/>
                            </h1>
                            <group>
                                <field name="tier" widget="badge" options="{'color': 'info'}"/>
                            </group>
                        </div>
                        <notebook>
                            <page string="Contact">
                                <group>
                                    <group name="contact_left">
                                        <field name="phone" widget="phone" placeholder="+1 (555) 000-0000"/>
                                        <field name="email" widget="email"/>
                                        <field name="tags" widget="many2many_tags"/>
                                    </group>
                                    <group name="contact_right">
                                        <field name="address" placeholder="Street"/>
                                        <field name="city" placeholder="City"/>
                                        <field name="state_id" options="{'no_create': True}"/>
                                        <field name="country_id" options="{'no_create': True}"/>
                                        <field name="zip" placeholder="ZIP"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Statistics">
                                <group>
                                    <group name="stats_left">
                                        <field name="total_spent" widget="monetary"/>
                                        <field name="visit_count"/>
                                    </group>
                                    <group name="stats_right">
                                        <field name="last_visit"/>
                                        <field name="partner_id" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Notes">
                                <field name="notes" nolabel="1" placeholder="Internal notes about this customer..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="view_odfe_customer_kanban" model="ir.ui.view">
            <field name="name">odfe.customer.kanban</field>
            <field name="model">odfe.customer</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" default_group_by="tier">
                    <field name="name"/>
                    <field name="phone"/>
                    <field name="email"/>
                    <field name="image"/>
                    <field name="total_spent"/>
                    <field name="visit_count"/>
                    <field name="tier"/>
                    <field name="city"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_image">
                                    <img t-att-src="kanban_image('odfe.customer', 'image', record.id.value)"
                                         t-att-alt="record.name.value"
                                         style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover;"
                                         alt="Customer Photo"/>
                                </div>
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div t-if="record.phone.value" class="o_kanban_record_subtitle">
                                        <i class="fa fa-phone"/> <field name="phone"/>
                                    </div>
                                    <div t-if="record.email.value" class="o_kanban_record_subtitle">
                                        <i class="fa fa-envelope"/> <field name="email"/>
                                    </div>
                                    <div t-if="record.city.value" class="o_kanban_record_subtitle">
                                        <i class="fa fa-map-marker"/> <field name="city"/>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <span class="o_kanban_primary_left">
                                            <field name="total_spent" widget="monetary"/>
                                        </span>
                                        <span class="o_kanban_primary_right">
                                            <field name="visit_count"/> visits
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_odfe_customer_search" model="ir.ui.view">
            <field name="name">odfe.customer.search</field>
            <field name="model">odfe.customer</field>
            <field name="arch" type="xml">
                <search string="Search Customers">
                    <field name="name" filter_domain="['|', ('name', 'ilike', self), ('phone', 'ilike', self)]"
                           placeholder="Search by name or phone..."/>
                    <field name="phone"/>
                    <field name="email"/>
                    <field name="city"/>
                    <field name="tags" filter_domain="[('tags', 'in', self)]"/>
                    <filter name="group_tier" string="Tier" context="{'group_by': 'tier'}"/>
                    <filter name="group_city" string="City" context="{'group_by': 'city'}"/>
                    <separator/>
                    <filter name="top_customers" string="Top Spenders"
                            domain="[('total_spent', '>', 0)]"/>
                    <filter name="frequent" string="Frequent"
                            domain="[('visit_count', '>=', 5)]"/>
                    <filter name="inactive" string="Archived"
                            domain="[('active', '=', False)]"/>
                    <separator/>
                    <filter name="this_month" string="Visited This Month"
                            date="last_visit"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_odfe_customer" model="ir.actions.act_window">
            <field name="name">Customers</field>
            <field name="res_model">odfe.customer</field>
            <field name="view_mode">tree,kanban,form</field>
            <field name="search_view_id" ref="view_odfe_customer_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first customer
                </p>
                <p>
                    Manage your restaurant customer profiles and track their visit history and spending.
                </p>
            </field>
        </record>

        <!-- Customer Tags -->
        <record id="view_odfe_customer_tag_tree" model="ir.ui.view">
            <field name="name">odfe.customer.tag.tree</field>
            <field name="model">odfe.customer.tag</field>
            <field name="arch" type="xml">
                <tree string="Customer Tags" editable="bottom">
                    <field name="name"/>
                    <field name="color" widget="color"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record id="action_odfe_customer_tag" model="ir.actions.act_window">
            <field name="name">Customer Tags</field>
            <field name="res_model">odfe.customer.tag</field>
            <field name="view_mode">tree</field>
        </record>

    </data>
</odoo>
