<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="CustomerDisplay" name="odfe_customer_display.CustomerDisplay">
        <t t-call="web.html_container">
            <div class="cd-container" id="customer-display-app"
                 t-att-data-display-id="display_id">
                <div class="cd-header">
                    <h1 class="cd-title">Welcome</h1>
                </div>
                <div class="cd-body" id="display-body">
                    <div class="cd-loading">
                        <i class="fa fa-spinner fa-spin fa-3x"/>
                        <p>Loading display...</p>
                    </div>
                </div>
            </div>
            <script type="text/javascript">
                require('odfe_customer_display/static/src/js/customer_display_app').default();
            </script>
        </t>
    </template>

    <template id="IdleScreen" name="odfe_customer_display.IdleScreen">
        <div class="cd-screen cd-idle">
            <div class="cd-idle-content">
                <div class="cd-idle-logo">
                    <i class="fa fa-cutlery fa-5x"/>
                </div>
                <h2 class="cd-idle-title">Scan to Order</h2>
                <div class="cd-idle-qr">
                    <div class="cd-qr-placeholder">
                        <i class="fa fa-qrcode fa-4x"/>
                        <p>Self-order menu</p>
                    </div>
                </div>
                <div class="cd-idle-promo">
                    <p class="cd-idle-promo-text">Today's Special</p>
                    <p class="cd-idle-promo-desc">Ask your server for details</p>
                </div>
            </div>
        </div>
    </template>

    <template id="OrderDisplay" name="odfe_customer_display.OrderDisplay">
        <div class="cd-screen cd-order">
            <div class="cd-order-header">
                <h2 class="cd-order-title">Your Order</h2>
                <p class="cd-order-name" t-if="data.order_name">
                    <t t-esc="data.order_name"/>
                </p>
            </div>
            <div class="cd-order-items">
                <div t-foreach="data.lines" t-as="line" class="cd-order-item">
                    <div class="cd-order-item-info">
                        <span class="cd-order-item-name"><t t-esc="line.product_name"/></span>
                        <span class="cd-order-item-qty"><t t-esc="line.quantity"/>x</span>
                    </div>
                    <span class="cd-order-item-price">
                        <t t-esc="'%.2f' % float(line.price_unit)"/>
                    </span>
                </div>
            </div>
            <div class="cd-order-totals">
                <div class="cd-order-total-row">
                    <span>Subtotal</span>
                    <span><t t-esc="'%.2f' % float(data.subtotal)"/></span>
                </div>
                <div class="cd-order-total-row">
                    <span>Tax</span>
                    <span><t t-esc="'%.2f' % float(data.tax_amount)"/></span>
                </div>
                <div class="cd-order-total-row cd-order-total-final">
                    <span>Total</span>
                    <span class="cd-order-total-amount">
                        <t t-esc="'%.2f' % float(data.total)"/>
                    </span>
                </div>
            </div>
        </div>
    </template>

    <template id="PaymentDisplay" name="odfe_customer_display.PaymentDisplay">
        <div class="cd-screen cd-payment">
            <div class="cd-payment-header">
                <h2 class="cd-payment-title">Ready to Pay</h2>
            </div>
            <div class="cd-payment-amount">
                <span class="cd-payment-label">Total Due</span>
                <span class="cd-payment-value">
                    <t t-esc="'%.2f' % float(amount_due)"/>
                </span>
            </div>
            <div class="cd-payment-qr">
                <img t-att-src="qr_data" t-if="qr_data" alt="Payment QR" class="cd-qr-image"/>
                <div t-else="" class="cd-qr-placeholder cd-qr-placeholder-large">
                    <i class="fa fa-qrcode fa-5x"/>
                    <p>Scan to Pay</p>
                </div>
            </div>
            <div class="cd-payment-footer">
                <p>Scan the QR code with any UPI app to pay</p>
            </div>
        </div>
    </template>

    <template id="ThankYouScreen" name="odfe_customer_display.ThankYouScreen">
        <div class="cd-screen cd-thankyou">
            <div class="cd-thankyou-content">
                <div class="cd-thankyou-icon">
                    <div class="cd-checkmark-circle">
                        <i class="fa fa-check cd-checkmark"/>
                    </div>
                </div>
                <h2 class="cd-thankyou-title">Thank You!</h2>
                <p class="cd-thankyou-message">Please visit again.</p>
                <div class="cd-thankyou-decoration">
                    <i class="fa fa-star cd-star" t-foreach="5" t-as="i"/>
                </div>
            </div>
        </div>
    </template>
</odoo>
