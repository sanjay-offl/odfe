<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="odfe_customer_display_action" model="ir.actions.act_window">
        <field name="name">Customer Displays</field>
        <field name="res_model">odfe.customer.display</field>
        <field name="view_mode">tree,form</field>
        <field name="help">Manage customer-facing display screens.</field>
    </record>

    <record id="odfe_customer_display_open_action" model="ir.actions.act_url">
        <field name="name">Open Customer Display</field>
        <field name="url">/customer/display</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_odfe_customer_display"
              name="Customer Display"
              parent="odfe_base.menu_odfe_root"
              action="odfe_customer_display_action"
              sequence="950"
              groups="base.group_user"/>

    <menuitem id="menu_odfe_customer_display_open"
              name="Open Display Screen"
              parent="odfe_base.menu_odfe_root"
              action="odfe_customer_display_open_action"
              sequence="55"
              groups="base.group_user"/>
</odoo>
