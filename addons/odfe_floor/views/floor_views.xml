<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_odfe_floor_tree" model="ir.ui.view">
    <field name="name">odfe.floor.tree</field>
    <field name="model">odfe.floor</field>
    <field name="arch" type="xml">
      <tree>
        <field name="sequence" widget="handle"/>
        <field name="code"/>
        <field name="name"/>
        <field name="color" widget="color_picker"/>
        <field name="active" optional="show"/>
      </tree>
    </field>
  </record>

  <record id="view_odfe_floor_form" model="ir.ui.view">
    <field name="name">odfe.floor.form</field>
    <field name="model">odfe.floor</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <widget name="web_ribbon" title="Archived" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
          <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
          <div class="oe_title">
            <label for="name" string="Floor" class="oe_edit_only"/>
            <h1>
              <field name="name" placeholder="Floor name..."/>
            </h1>
            <h2>
              <field name="code" placeholder="Floor code..."/>
            </h2>
          </div>
          <group>
            <group>
              <field name="sequence"/>
              <field name="color" widget="color_picker"/>
            </group>
            <group>
              <field name="active"/>
            </group>
          </group>
          <notebook>
            <page name="tables" string="Tables">
              <field name="table_ids">
                <tree>
                  <field name="name"/>
                  <field name="capacity"/>
                  <field name="shape"/>
                  <field name="state" decoration-success="state == 'free'" decoration-warning="state == 'occupied'" decoration-info="state == 'reserved'" decoration-muted="state == 'maintenance'"/>
                  <field name="pos_x"/>
                  <field name="pos_y"/>
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_odfe_floor_kanban" model="ir.ui.view">
    <field name="name">odfe.floor.kanban</field>
    <field name="model">odfe.floor</field>
    <field name="arch" type="xml">
      <kanban class="o_odfe_floor_kanban">
        <field name="color"/>
        <field name="name"/>
        <field name="code"/>
        <field name="table_ids"/>
        <templates>
          <t t-name="kanban-box">
            <div class="oe_kanban_global_click" attrs="{'style': 'border-top: 3px solid %%s' % (kanban_getcolored(record.color.raw_value or 0) if record.color.raw_value else '#ccc')}">
              <div class="o_kanban_image">
                <field name="image" widget="image" class="o_image_64_cover"/>
              </div>
              <div class="oe_kanban_details">
                <strong class="o_kanban_record_title">
                  <field name="name"/>
                </strong>
                <div class="text-muted o_kanban_record_subtitle">
                  <field name="code"/>
                </div>
                <div class="o_kanban_record_bottom">
                  <span class="o_kanban_record_bottom_right">
                    <t t-esc="record.table_ids.length or 0"/> Tables
                  </span>
                </div>
              </div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <record id="action_odfe_floor" model="ir.actions.act_window">
    <field name="name">Floors</field>
    <field name="res_model">odfe.floor</field>
    <field name="view_mode">kanban,tree,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Create a new floor for your restaurant
      </p>
      <p>
        Floors help organize your restaurant space. You can define tables on each floor with their positions for a visual floor plan.
      </p>
    </field>
  </record>
</odoo>
