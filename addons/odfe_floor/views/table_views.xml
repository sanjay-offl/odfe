<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_odfe_table_tree" model="ir.ui.view">
    <field name="name">odfe.table.tree</field>
    <field name="model">odfe.table</field>
    <field name="arch" type="xml">
      <tree decoration-success="state == 'free'" decoration-warning="state == 'occupied'" decoration-info="state == 'reserved'" decoration-muted="state == 'maintenance'">
        <field name="name"/>
        <field name="floor_id"/>
        <field name="capacity"/>
        <field name="shape"/>
        <field name="state" widget="badge" decoration-success="state == 'free'" decoration-warning="state == 'occupied'" decoration-info="state == 'reserved'" decoration-muted="state == 'maintenance'"/>
        <field name="current_order_id"/>
        <field name="active" optional="show"/>
      </tree>
    </field>
  </record>

  <record id="view_odfe_table_form" model="ir.ui.view">
    <field name="name">odfe.table.form</field>
    <field name="model">odfe.table</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <widget name="web_ribbon" title="Archived" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
          <div class="oe_title">
            <label for="name" string="Table" class="oe_edit_only"/>
            <h1>
              <field name="name" placeholder="Table name..."/>
            </h1>
          </div>
          <group>
            <group>
              <field name="floor_id" options="{'no_create': True}"/>
              <field name="capacity"/>
              <field name="shape"/>
            </group>
            <group>
              <field name="state" widget="badge" decoration-success="state == 'free'" decoration-warning="state == 'occupied'" decoration-info="state == 'reserved'" decoration-muted="state == 'maintenance'"/>
              <field name="current_order_id"/>
              <field name="active"/>
            </group>
          </group>
          <group string="Floor Plan Position">
            <group>
              <field name="pos_x"/>
              <field name="pos_y"/>
            </group>
            <group>
              <field name="width"/>
              <field name="height"/>
            </group>
          </group>
          <group string="Self Order URL" attrs="{'invisible': [('qr_code', '=', False)]}">
            <field name="qr_code" string="QR Data"/>
          </group>
          <notebook>
            <page name="status_history" string="Status History">
              <field name="status_change_ids">
                <tree>
                  <field name="changed_at"/>
                  <field name="state_from" decoration-success="state_from == 'free'" decoration-warning="state_from == 'occupied'" decoration-info="state_from == 'reserved'" decoration-muted="state_from == 'maintenance'"/>
                  <field name="state_to" decoration-success="state_to == 'free'" decoration-warning="state_to == 'occupied'" decoration-info="state_to == 'reserved'" decoration-muted="state_to == 'maintenance'"/>
                  <field name="changed_by"/>
                  <field name="order_id"/>
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_odfe_table_search" model="ir.ui.view">
    <field name="name">odfe.table.search</field>
    <field name="model">odfe.table</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="floor_id"/>
        <filter name="filter_free" string="Free" domain="[('state', '=', 'free')]"/>
        <filter name="filter_occupied" string="Occupied" domain="[('state', '=', 'occupied')]"/>
        <filter name="filter_reserved" string="Reserved" domain="[('state', '=', 'reserved')]"/>
        <filter name="filter_maintenance" string="Maintenance" domain="[('state', '=', 'maintenance')]"/>
        <separator/>
        <filter name="group_floor" string="Floor" context="{'group_by': 'floor_id'}"/>
      </search>
    </field>
  </record>

  <record id="action_odfe_table" model="ir.actions.act_window">
    <field name="name">Tables</field>
    <field name="res_model">odfe.table</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="view_odfe_table_search"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Create a new table
      </p>
      <p>
        Tables represent physical tables in your restaurant. Assign them to a floor and set their position for the visual floor plan.
      </p>
    </field>
  </record>
</odoo>
