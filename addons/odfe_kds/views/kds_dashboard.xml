<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="KDSDashboard" name="odfe_kds.KDSDashboard">
        <t t-call="web.html_container">
            <div class="odfe-kds">
                <!-- Header -->
                <div class="odfe-kds-header">
                    <div class="odfe-kds-header__brand">
                        <div style="width: 40px; height: 40px; border-radius: 12px; background: linear-gradient(135deg, var(--odfe-primary), var(--odfe-accent)); display: flex; align-items: center; justify-content: center; color: white; font-weight: 800; font-size: 16px; box-shadow: 0 4px 12px rgba(20, 184, 166, 0.3);">K</div>
                        <span>Barista Board</span>
                    </div>
                    <div class="odfe-kds-header__stats">
                        <div class="odfe-kds-header__stat">
                            <div class="odfe-kds-header__stat-value" id="kds-order-count">0 active</div>
                            <div class="odfe-kds-header__stat-label">Orders</div>
                        </div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 16px;">
                        <Filters filterOptions="state.filterOptions" activeFilter="state.activeFilter" setFilter="setFilter"/>
                        <button class="odfe-kds-sound" t-on-click="toggleSound" t-att-class="state.soundEnabled ? '' : 'muted'">
                            <i t-att-class="state.soundEnabled ? 'fa fa-volume-up' : 'fa fa-volume-off'"/>
                        </button>
                        <div class="odfe-kds-header__clock" id="kds-clock"/>
                    </div>
                </div>

                <!-- Four Columns: New, Brewing, Ready, Collected -->
                <div class="odfe-kds-columns">
                    <!-- New Orders -->
                    <div class="odfe-kds-column">
                        <div class="odfe-kds-column__header odfe-kds-column__header--new">
                            <span><i class="fa fa-bell" style="margin-right: 8px;"/> New</span>
                            <span class="odfe-kds-column__count" t-out="state.filteredOrders.filter(o => o.state === 'pending').length"/>
                        </div>
                        <div class="odfe-kds-column__body">
                            <t t-foreach="state.filteredOrders" t-as="order" t-key="order.id">
                                <TicketCard t-if="order.state === 'pending'"
                                    order="order"
                                    onAccept="acceptOrder"
                                    onStart="startOrder"
                                    onComplete="completeOrder"
                                    onCollect="() => {}"/>
                            </t>
                        </div>
                    </div>

                    <!-- Brewing -->
                    <div class="odfe-kds-column">
                        <div class="odfe-kds-column__header odfe-kds-column__header--brewing">
                            <span><i class="fa fa-fire" style="margin-right: 8px;"/> Brewing</span>
                            <span class="odfe-kds-column__count" t-out="state.filteredOrders.filter(o => o.state === 'preparing').length"/>
                        </div>
                        <div class="odfe-kds-column__body">
                            <t t-foreach="state.filteredOrders" t-as="order" t-key="order.id">
                                <TicketCard t-if="order.state === 'preparing'"
                                    order="order"
                                    onAccept="acceptOrder"
                                    onStart="startOrder"
                                    onComplete="completeOrder"
                                    onCollect="() => {}"/>
                            </t>
                        </div>
                    </div>

                    <!-- Ready -->
                    <div class="odfe-kds-column">
                        <div class="odfe-kds-column__header odfe-kds-column__header--ready">
                            <span><i class="fa fa-check-circle" style="margin-right: 8px;"/> Ready</span>
                            <span class="odfe-kds-column__count" t-out="state.filteredOrders.filter(o => o.state === 'ready').length"/>
                        </div>
                        <div class="odfe-kds-column__body">
                            <t t-foreach="state.filteredOrders" t-as="order" t-key="order.id">
                                <TicketCard t-if="order.state === 'ready'"
                                    order="order"
                                    onAccept="acceptOrder"
                                    onStart="startOrder"
                                    onComplete="completeOrder"
                                    onCollect="completeOrder"/>
                            </t>
                        </div>
                    </div>

                    <!-- Collected -->
                    <div class="odfe-kds-column">
                        <div class="odfe-kds-column__header odfe-kds-column__header--collected">
                            <span><i class="fa fa-inbox" style="margin-right: 8px;"/> Collected</span>
                            <span class="odfe-kds-column__count" t-out="state.filteredOrders.filter(o => o.state === 'completed').length"/>
                        </div>
                        <div class="odfe-kds-column__body">
                            <t t-foreach="state.filteredOrders" t-as="order" t-key="order.id">
                                <TicketCard t-if="order.state === 'completed'"
                                    order="order"
                                    onAccept="acceptOrder"
                                    onStart="startOrder"
                                    onComplete="completeOrder"
                                    onCollect="() => {}"/>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="KitchenBoard" name="odfe_kds.KitchenBoard">
        <!-- Deprecated: Using column layout in KDSDashboard -->
    </template>

    <template id="TicketCard" name="odfe_kds.TicketCard">
        <div class="odfe-kds-ticket"
            t-att-class="props.order.priority === 'urgent' ? 'odfe-kds-ticket--urgent' : (props.order.priority === 'high' ? 'odfe-kds-ticket--warning' : '')">
            <div class="odfe-kds-ticket__header">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <span class="odfe-kds-ticket__order">#<t t-out="props.order.name"/></span>
                    <span class="odfe-kds-ticket__table" t-if="props.order.table_name">
                        <i class="fa fa-cutlery" style="margin-right: 2px;"/> <t t-out="props.order.table_name"/>
                    </span>
                    <span class="odfe-kds-ticket__table" t-else="">
                        <i class="fa fa-shopping-bag" style="margin-right: 2px;"/> Takeaway
                    </span>
                </div>
                <span class="odfe-kds-ticket__priority" t-if="props.order.priority === 'urgent'">
                    <i class="fa fa-bolt" style="margin-right: 2px;"/> URGENT
                </span>
            </div>

            <div class="odfe-kds-ticket__timer" t-att-data-created="props.order.created_at">
                00:00
            </div>

            <div class="odfe-kds-ticket__customer" t-if="props.order.customer_name">
                <i class="fa fa-user" style="margin-right: 4px;"/> <t t-out="props.order.customer_name"/>
            </div>

            <div class="odfe-kds-ticket__items">
                <div t-foreach="props.order.items" t-as="item" t-key="item.id" class="odfe-kds-ticket__item">
                    <div style="display: flex; align-items: flex-start; gap: 8px; flex: 1;">
                        <span class="odfe-kds-ticket__item-qty"><t t-esc="item.quantity"/>x</span>
                        <div style="flex: 1;">
                            <div class="odfe-kds-ticket__item-name"><t t-out="item.product_name"/></div>
                            <div class="odfe-kds-ticket__item-note" t-if="item.note">
                                <i class="fa fa-comment" style="margin-right: 4px;"/> <t t-out="item.note"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="odfe-kds-ticket__footer" t-if="props.order.note">
                <div style="font-size: 12px; color: var(--odfe-caramel); font-style: italic;">
                    <i class="fa fa-sticky-note" style="margin-right: 4px;"/> <t t-out="props.order.note"/>
                </div>
            </div>

            <div class="odfe-kds-ticket__footer">
                <div class="odfe-kds-ticket__estimated">
                    <span>Est: <t t-out="props.order.estimated_time || '5'"/> min</span>
                    <span><t t-out="props.order.items.length"/> items</span>
                </div>
                <button t-if="props.order.state === 'pending'"
                    class="odfe-kds-ticket__action odfe-kds-ticket__action--accept"
                    t-on-click="() => props.onAccept(props.order.id)">
                    <i class="fa fa-check" style="margin-right: 4px;"/> Accept
                </button>
                <button t-if="props.order.state === 'preparing'"
                    class="odfe-kds-ticket__action odfe-kds-ticket__action--complete"
                    t-on-click="() => props.onComplete(props.order.id)">
                    <i class="fa fa-check-circle" style="margin-right: 4px;"/> Ready
                </button>
                <button t-if="props.order.state === 'ready'"
                    class="odfe-kds-ticket__action odfe-kds-ticket__action--collect"
                    t-on-click="() => props.onCollect(props.order.id)">
                    <i class="fa fa-inbox" style="margin-right: 4px;"/> Collect
                </button>
                <span t-if="props.order.state === 'completed'" style="font-size: 12px; color: var(--odfe-success); font-weight: 600;">
                    <i class="fa fa-check-circle" style="margin-right: 4px;"/> Completed
                </span>
            </div>
        </div>
    </template>

    <template id="Filters" name="odfe_kds.Filters">
        <div style="display: flex; gap: 4px; background: rgba(255,255,255,0.06); border-radius: 12px; padding: 3px; border: 1px solid rgba(255,255,255,0.08);">
            <button t-foreach="props.filterOptions" t-as="opt" t-key="opt.value"
                style="padding: 6px 14px; border-radius: 10px; border: none; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s; min-height: 34px;"
                t-att-style="props.activeFilter === opt.value ? 'background: var(--odfe-primary); color: white;' : 'background: transparent; color: var(--odfe-text-secondary);'"
                t-on-click="() => props.setFilter(opt.value)">
                <t t-out="opt.label"/>
            </button>
        </div>
    </template>

    <template id="Search" name="odfe_kds.Search">
        <div style="position: relative;">
            <i class="fa fa-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--odfe-text-tertiary); font-size: 14px;"/>
            <input type="text" t-model="state.searchQuery" t-on-input="() => props.onSearch(state.searchQuery)"
                style="padding: 8px 12px 8px 36px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; color: var(--odfe-text-primary); font-size: 13px; width: 200px; outline: none;"
                placeholder="Search orders..."/>
            <button t-if="state.searchQuery" t-on-click="() => { state.searchQuery = ''; props.clearSearch(); }"
                style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--odfe-text-tertiary); cursor: pointer; font-size: 16px; padding: 4px;">&#215;</button>
        </div>
    </template>
</odoo>
