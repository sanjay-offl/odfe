<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kitchen_order_tree" model="ir.ui.view">
        <field name="name">odfe.kitchen.order.tree</field>
        <field name="model">odfe.kitchen.order</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="table_name"/>
                <field name="state" widget="badge" decoration-danger="state == 'cancelled'" decoration-success="state == 'completed'" decoration-info="state == 'preparing'" decoration-warning="state == 'pending'"/>
                <field name="priority"/>
                <field name="total_items"/>
                <field name="completed_items"/>
                <field name="created_at"/>
            </tree>
        </field>
    </record>

    <record id="view_kitchen_order_form" model="ir.ui.view">
        <field name="name">odfe.kitchen.order.form</field>
        <field name="model">odfe.kitchen.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_accept" type="object" string="Accept" states="pending" class="btn-primary"/>
                    <button name="action_start_preparing" type="object" string="Start Preparing" states="accepted" class="btn-warning"/>
                    <button name="action_complete" type="object" string="Complete" states="preparing" class="btn-success"/>
                    <button name="action_cancel" type="object" string="Cancel" states="pending,accepted,preparing" class="btn-danger" confirm="Cancel this order?"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,accepted,preparing,completed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="pos_order_id"/>
                            <field name="table_name"/>
                            <field name="customer_name"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="total_items"/>
                            <field name="completed_items"/>
                            <field name="created_at"/>
                            <field name="started_at"/>
                            <field name="completed_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Items">
                            <field name="item_ids">
                                <tree editable="bottom">
                                    <field name="product_name"/>
                                    <field name="quantity"/>
                                    <field name="state" widget="badge"/>
                                    <field name="preparation_time"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kitchen_order_search" model="ir.ui.view">
        <field name="name">odfe.kitchen.order.search</field>
        <field name="model">odfe.kitchen.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="table_name"/>
                <filter name="filter_pending" string="Pending" domain="[('state','=','pending')]"/>
                <filter name="filter_preparing" string="Preparing" domain="[('state','=','preparing')]"/>
                <filter name="filter_completed" string="Completed" domain="[('state','=','completed')]"/>
                <separator/>
                <filter name="filter_urgent" string="Urgent" domain="[('priority','=','urgent')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                    <filter name="group_priority" string="Priority" context="{'group_by':'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kitchen_order" model="ir.actions.act_window">
        <field name="name">Kitchen Orders</field>
        <field name="res_model">odfe.kitchen.order</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p>Kitchen orders from the POS system. Accept, prepare, and complete orders here.</p>
        </field>
    </record>

    <record id="view_kitchen_item_tree" model="ir.ui.view">
        <field name="name">odfe.kitchen.item.tree</field>
        <field name="model">odfe.kitchen.item</field>
        <field name="arch" type="xml">
            <tree>
                <field name="kitchen_order_id"/>
                <field name="product_name"/>
                <field name="quantity"/>
                <field name="state" widget="badge"/>
                <field name="preparation_time"/>
                <field name="sequence"/>
            </tree>
        </field>
    </record>

    <record id="action_kitchen_item" model="ir.actions.act_window">
        <field name="name">Kitchen Items</field>
        <field name="res_model">odfe.kitchen.item</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_kitchen_status_tree" model="ir.ui.view">
        <field name="name">odfe.kitchen.status.tree</field>
        <field name="model">odfe.kitchen.status</field>
        <field name="arch" type="xml">
            <tree>
                <field name="kitchen_order_id"/>
                <field name="state_from"/>
                <field name="state_to"/>
                <field name="changed_by"/>
                <field name="changed_at"/>
                <field name="duration_seconds"/>
            </tree>
        </field>
    </record>

    <record id="action_kitchen_status" model="ir.actions.act_window">
        <field name="name">Kitchen Status Log</field>
        <field name="res_model">odfe.kitchen.status</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
