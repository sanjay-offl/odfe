<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Session sequences -->
        <record id="seq_pos_session" model="ir.sequence">
            <field name="name">POS Session</field>
            <field name="code">odfe.pos.session</field>
            <field name="prefix">SES/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Order sequences -->
        <record id="seq_pos_order" model="ir.sequence">
            <field name="name">POS Order</field>
            <field name="code">odfe.pos.order</field>
            <field name="prefix">ORD/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Receipt sequences -->
        <record id="seq_pos_receipt" model="ir.sequence">
            <field name="name">POS Receipt</field>
            <field name="code">odfe.pos.receipt</field>
            <field name="prefix">RCP/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
