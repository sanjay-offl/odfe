<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Record rules for POS sessions -->
        <record id="rule_pos_session_user" model="ir.rule">
            <field name="name">POS Session: User sees own sessions</field>
            <field name="model_id" ref="model_odfe_pos_session"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('odfe_base.group_pos_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_pos_session_manager" model="ir.rule">
            <field name="name">POS Session: Manager sees all</field>
            <field name="model_id" ref="model_odfe_pos_session"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('odfe_base.group_pos_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record rules for POS orders -->
        <record id="rule_pos_order_user" model="ir.rule">
            <field name="name">POS Order: User sees own session orders</field>
            <field name="model_id" ref="model_odfe_pos_order"/>
            <field name="domain_force">[('session_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('odfe_base.group_pos_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_pos_order_manager" model="ir.rule">
            <field name="name">POS Order: Manager sees all</field>
            <field name="model_id" ref="model_odfe_pos_order"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('odfe_base.group_pos_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
