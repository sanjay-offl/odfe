<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- DRINK CUSTOMIZATION DRAWER                                 -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <template id="CustomizationDrawer" name="odfe_pos.CustomizationDrawer">
        <div class="odfe-overlay" t-on-click="() => props.onClose()">
            <div class="odfe-drawer" t-on-click.stop="">
                <!-- Drawer Header -->
                <div class="odfe-drawer__header">
                    <div class="odfe-drawer__header-left">
                        <div class="odfe-drawer__product-icon">
                            <i class="fa fa-coffee"/>
                        </div>
                        <div class="odfe-drawer__product-info">
                            <div class="odfe-drawer__product-name" t-out="props.product.name"/>
                            <div class="odfe-drawer__product-price">
                                <span class="odfe-drawer__product-price-currency">₹</span>
                                <span class="odfe-drawer__product-price-value" t-esc="props.product.price"/>
                            </div>
                        </div>
                    </div>
                    <button class="odfe-drawer__close" t-on-click="() => props.onClose()">
                        <i class="fa fa-times"/>
                    </button>
                </div>

                <!-- Drawer Scrollable Body -->
                <div class="odfe-drawer__body">
                    <!-- Cup Size Section -->
                    <div class="odfe-drawer__section">
                        <div class="odfe-drawer__section-header">
                            <div class="odfe-drawer__section-title">Cup Size</div>
                            <div class="odfe-drawer__section-subtitle">Choose your preferred size</div>
                        </div>
                        <div class="odfe-drawer__pill-grid">
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('size', 'small', 0)"
                                 t-att-class="state.size === 'small' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-coffee"/></div>
                                <div class="odfe-drawer__pill-label">Small</div>
                                <div class="odfe-drawer__pill-price">₹0</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('size', 'medium', 10)"
                                 t-att-class="state.size === 'medium' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-coffee"/></div>
                                <div class="odfe-drawer__pill-label">Medium</div>
                                <div class="odfe-drawer__pill-price">+₹10</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('size', 'large', 20)"
                                 t-att-class="state.size === 'large' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-coffee"/></div>
                                <div class="odfe-drawer__pill-label">Large</div>
                                <div class="odfe-drawer__pill-price">+₹20</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('size', 'extra_large', 30)"
                                 t-att-class="state.size === 'extra_large' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-coffee"/></div>
                                <div class="odfe-drawer__pill-label">Extra Large</div>
                                <div class="odfe-drawer__pill-price">+₹30</div>
                            </div>
                        </div>
                    </div>

                    <!-- Temperature Section -->
                    <div class="odfe-drawer__section">
                        <div class="odfe-drawer__section-header">
                            <div class="odfe-drawer__section-title">Temperature</div>
                            <div class="odfe-drawer__section-subtitle">How hot do you like it?</div>
                        </div>
                        <div class="odfe-drawer__pill-grid">
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('temperature', 'hot', 0)"
                                 t-att-class="state.temperature === 'hot' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-fire"/></div>
                                <div class="odfe-drawer__pill-label">Hot</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('temperature', 'warm', 0)"
                                 t-att-class="state.temperature === 'warm' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-sun-o"/></div>
                                <div class="odfe-drawer__pill-label">Warm</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('temperature', 'iced', 0)"
                                 t-att-class="state.temperature === 'iced' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-snowflake-o"/></div>
                                <div class="odfe-drawer__pill-label">Iced</div>
                            </div>
                        </div>
                    </div>

                    <!-- Milk Section -->
                    <div class="odfe-drawer__section">
                        <div class="odfe-drawer__section-header">
                            <div class="odfe-drawer__section-title">Milk</div>
                            <div class="odfe-drawer__section-subtitle">Select your milk type</div>
                        </div>
                        <div class="odfe-drawer__pill-grid">
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('milk', 'whole', 0)"
                                 t-att-class="state.milk === 'whole' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-tint"/></div>
                                <div class="odfe-drawer__pill-label">Whole</div>
                                <div class="odfe-drawer__pill-price" t-if="0">₹0</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('milk', 'skimmed', 0)"
                                 t-att-class="state.milk === 'skimmed' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-tint"/></div>
                                <div class="odfe-drawer__pill-label">Skimmed</div>
                                <div class="odfe-drawer__pill-price" t-if="0">₹0</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('milk', 'oat', 30)"
                                 t-att-class="state.milk === 'oat' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-leaf"/></div>
                                <div class="odfe-drawer__pill-label">Oat</div>
                                <div class="odfe-drawer__pill-price">+₹30</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('milk', 'almond', 30)"
                                 t-att-class="state.milk === 'almond' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-leaf"/></div>
                                <div class="odfe-drawer__pill-label">Almond</div>
                                <div class="odfe-drawer__pill-price">+₹30</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('milk', 'soy', 25)"
                                 t-att-class="state.milk === 'soy' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-leaf"/></div>
                                <div class="odfe-drawer__pill-label">Soy</div>
                                <div class="odfe-drawer__pill-price">+₹25</div>
                            </div>
                        </div>
                    </div>

                    <!-- Sugar Section -->
                    <div class="odfe-drawer__section">
                        <div class="odfe-drawer__section-header">
                            <div class="odfe-drawer__section-title">Sugar</div>
                            <div class="odfe-drawer__section-subtitle">Sweetness level</div>
                        </div>
                        <div class="odfe-drawer__pill-grid">
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('sugar', 'none', 0)"
                                 t-att-class="state.sugar === 'none' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-ban"/></div>
                                <div class="odfe-drawer__pill-label">No Sugar</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('sugar', 'less', 0)"
                                 t-att-class="state.sugar === 'less' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-minus"/></div>
                                <div class="odfe-drawer__pill-label">Less</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('sugar', 'regular', 0)"
                                 t-att-class="state.sugar === 'regular' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-check"/></div>
                                <div class="odfe-drawer__pill-label">Regular</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('sugar', 'extra', 0)"
                                 t-att-class="state.sugar === 'extra' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-plus"/></div>
                                <div class="odfe-drawer__pill-label">Extra</div>
                            </div>
                        </div>
                    </div>

                    <!-- Flavor Section -->
                    <div class="odfe-drawer__section">
                        <div class="odfe-drawer__section-header">
                            <div class="odfe-drawer__section-title">Flavor</div>
                            <div class="odfe-drawer__section-subtitle">Add a flavor boost</div>
                        </div>
                        <div class="odfe-drawer__pill-grid">
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('flavor', 'none', 0)"
                                 t-att-class="state.flavor === 'none' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-times"/></div>
                                <div class="odfe-drawer__pill-label">None</div>
                                <div class="odfe-drawer__pill-price" t-if="0">₹0</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('flavor', 'vanilla', 20)"
                                 t-att-class="state.flavor === 'vanilla' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-tint"/></div>
                                <div class="odfe-drawer__pill-label">Vanilla</div>
                                <div class="odfe-drawer__pill-price">+₹20</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('flavor', 'caramel', 20)"
                                 t-att-class="state.flavor === 'caramel' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-tint"/></div>
                                <div class="odfe-drawer__pill-label">Caramel</div>
                                <div class="odfe-drawer__pill-price">+₹20</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('flavor', 'hazelnut', 25)"
                                 t-att-class="state.flavor === 'hazelnut' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-tint"/></div>
                                <div class="odfe-drawer__pill-label">Hazelnut</div>
                                <div class="odfe-drawer__pill-price">+₹25</div>
                            </div>
                            <div class="odfe-drawer__pill" t-on-click="() => selectOption('flavor', 'chocolate', 20)"
                                 t-att-class="state.flavor === 'chocolate' ? 'odfe-drawer__pill--selected' : ''">
                                <div class="odfe-drawer__pill-icon"><i class="fa fa-tint"/></div>
                                <div class="odfe-drawer__pill-label">Chocolate</div>
                                <div class="odfe-drawer__pill-price">+₹20</div>
                            </div>
                        </div>
                    </div>

                    <!-- Extras Section -->
                    <div class="odfe-drawer__section">
                        <div class="odfe-drawer__section-header">
                            <div class="odfe-drawer__section-title">Extras</div>
                            <div class="odfe-drawer__section-subtitle">Customize your drink</div>
                        </div>
                        <div class="odfe-drawer__toggle-list">
                            <div class="odfe-drawer__toggle" t-on-click="() => toggleExtra('extra_shot')">
                                <div class="odfe-drawer__toggle-info">
                                    <div class="odfe-drawer__toggle-label">Extra Shot</div>
                                    <div class="odfe-drawer__toggle-price">+₹40</div>
                                </div>
                                <div class="odfe-drawer__toggle-switch" t-att-class="state.extras.extra_shot ? 'odfe-drawer__toggle-switch--active' : ''">
                                    <div class="odfe-drawer__toggle-knob"/>
                                </div>
                            </div>
                            <div class="odfe-drawer__toggle" t-on-click="() => toggleExtra('whipped_cream')">
                                <div class="odfe-drawer__toggle-info">
                                    <div class="odfe-drawer__toggle-label">Whipped Cream</div>
                                    <div class="odfe-drawer__toggle-price">+₹25</div>
                                </div>
                                <div class="odfe-drawer__toggle-switch" t-att-class="state.extras.whipped_cream ? 'odfe-drawer__toggle-switch--active' : ''">
                                    <div class="odfe-drawer__toggle-knob"/>
                                </div>
                            </div>
                            <div class="odfe-drawer__toggle" t-on-click="() => toggleExtra('chocolate_drizzle')">
                                <div class="odfe-drawer__toggle-info">
                                    <div class="odfe-drawer__toggle-label">Chocolate Drizzle</div>
                                    <div class="odfe-drawer__toggle-price">+₹20</div>
                                </div>
                                <div class="odfe-drawer__toggle-switch" t-att-class="state.extras.chocolate_drizzle ? 'odfe-drawer__toggle-switch--active' : ''">
                                    <div class="odfe-drawer__toggle-knob"/>
                                </div>
                            </div>
                            <div class="odfe-drawer__toggle" t-on-click="() => toggleExtra('cinnamon')">
                                <div class="odfe-drawer__toggle-info">
                                    <div class="odfe-drawer__toggle-label">Cinnamon</div>
                                    <div class="odfe-drawer__toggle-price">Free</div>
                                </div>
                                <div class="odfe-drawer__toggle-switch" t-att-class="state.extras.cinnamon ? 'odfe-drawer__toggle-switch--active' : ''">
                                    <div class="odfe-drawer__toggle-knob"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Drawer Footer: Quantity + Add to Order -->
                <div class="odfe-drawer__footer">
                    <div class="odfe-drawer__quantity">
                        <button class="odfe-drawer__qty-btn" t-on-click="() => updateQuantity(state.quantity - 1)" t-att-disabled="state.quantity &lt;= 1">
                            <i class="fa fa-minus"/>
                        </button>
                        <div class="odfe-drawer__qty-value" t-out="state.quantity"/>
                        <button class="odfe-drawer__qty-btn" t-on-click="() => updateQuantity(state.quantity + 1)">
                            <i class="fa fa-plus"/>
                        </button>
                    </div>
                    <button class="odfe-drawer__add-btn" t-on-click="addToOrder">
                        <span>Add to Order</span>
                        <span class="odfe-drawer__add-btn-price">₹<t t-esc="state.totalPrice * state.quantity"/></span>
                    </button>
                </div>
            </div>
        </div>
    </template>
</odoo>
