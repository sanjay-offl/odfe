<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="pos_app" name="odfe_pos: POS App">
        <t t-call="web.html_container">
            <t t-raw="0"/>
        </t>
    </template>

    <template id="LoginScreen" name="odfe_pos.LoginScreen">
        <div class="odfe-login">
            <div class="odfe-login__visual">
                <div class="odfe-login__visual-content">
                    <i class="fa fa-cutlery odfe-login__visual-icon"/>
                    <h2 class="odfe-login__visual-title">Welcome to ODFE</h2>
                    <p class="odfe-login__visual-subtitle">Premium POS Experience</p>
                </div>
            </div>
            <div class="odfe-login__form-side">
                <div class="odfe-login__card">
                    <div class="odfe-login__logo">
                        <div class="odfe-login__logo-icon">O</div>
                        <h1>ODFE POS</h1>
                        <p>Sign in to your account</p>
                    </div>
                    <div class="odfe-login__field">
                        <label>Username</label>
                        <input type="text" t-model="state.username" placeholder="Enter username"/>
                    </div>
                    <div class="odfe-login__field">
                        <label>Password</label>
                        <input type="password" t-model="state.password" placeholder="Enter password"/>
                    </div>
                    <div class="odfe-login__error" t-if="state.error">
                        <t t-out="state.error"/>
                    </div>
                    <button class="odfe-login__submit" t-on-click="handleLogin">
                        Sign In
                    </button>
                </div>
            </div>
        </div>
    </template>

    <!-- Floor Popup using odfe-modal -->
    <template id="FloorPopup" name="odfe_pos.FloorPopup">
        <div class="odfe-modal__overlay" t-on-click="close">
            <div class="odfe-modal__content" t-on-click.stop="">
                <div class="odfe-modal__header">
                    <h2 class="odfe-modal__title">Select Floor</h2>
                    <button class="odfe-modal__close" t-on-click="close"><i class="fa fa-times"/></button>
                </div>
                <div class="odfe-modal__body">
                    <div class="odfe-floor-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
                        <div t-foreach="state.floors" t-as="floor" class="odfe-card" t-on-click="() => selectFloor(floor)" style="cursor: pointer;">
                            <div class="odfe-card__body" style="text-align: center;">
                                <i class="fa fa-building" style="font-size: 24px; color: var(--odfe-primary); margin-bottom: 8px;"/>
                                <div style="font-weight: 600;"><t t-out="floor.name"/></div>
                                <div style="font-size: 12px; color: var(--odfe-text-secondary);"><t t-out="floor.table_count"/> tables</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="OrderView" name="odfe_pos.OrderView">
        <div class="odfe-card">
            <div class="odfe-card__header" style="display: flex; justify-content: space-between; align-items: center;">
                <h2 class="odfe-card__title">Order #<t t-out="props.order.name"/></h2>
                <span class="odfe-badge odfe-badge--info"><t t-out="props.order.state"/></span>
            </div>
            <div class="odfe-card__body">
                <div t-foreach="props.order.lines" t-as="line" class="odfe-cart-item">
                    <div class="odfe-cart-item__info">
                        <div class="odfe-cart-item__name"><t t-out="line.product_name"/></div>
                    </div>
                    <div class="odfe-cart-item__qty" style="padding: 0 16px;"><t t-out="line.quantity"/>x</div>
                    <div class="odfe-cart-item__subtotal"><t t-esc="line.subtotal"/></div>
                </div>
                <hr style="border-color: var(--odfe-glass-border); margin: 16px 0; border-style: solid; border-width: 1px 0 0 0;"/>
                <div style="display: flex; justify-content: space-between; font-weight: 700;">
                    <span>Total</span>
                    <span><t t-esc="props.order.total"/></span>
                </div>
                <div style="display: flex; gap: 8px; margin-top: 16px;" t-if="props.order.state === 'draft' || props.order.state === 'confirmed'">
                    <button class="odfe-btn odfe-btn--primary" style="flex: 1;" t-on-click="() => props.onPay(props.order)">Pay</button>
                    <button class="odfe-btn odfe-btn--danger" style="flex: 1;" t-on-click="() => props.onCancel(props.order)">Cancel</button>
                </div>
            </div>
        </div>
    </template>

    <template id="Orders" name="odfe_pos.Orders">
        <div class="odfe-pos" style="padding: var(--odfe-space-6);">
            <div class="odfe-card">
                <div class="odfe-card__header" style="display: flex; justify-content: space-between; align-items: center;">
                    <h2 class="odfe-card__title">Order History</h2>
                    <div class="odfe-input-wrapper">
                        <input type="text" class="odfe-input" t-model="state.searchQuery" placeholder="Search orders..."/>
                    </div>
                </div>
                <div class="odfe-card__body">
                    <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                        <button t-on-click="() => filterOrders('all')" class="odfe-btn odfe-btn--outline" t-att-style="state.activeFilter === 'all' ? 'background: var(--odfe-glass-bg-hover)' : ''">All</button>
                        <button t-on-click="() => filterOrders('draft')" class="odfe-btn odfe-btn--outline" t-att-style="state.activeFilter === 'draft' ? 'background: var(--odfe-glass-bg-hover)' : ''">Draft</button>
                        <button t-on-click="() => filterOrders('paid')" class="odfe-btn odfe-btn--outline" t-att-style="state.activeFilter === 'paid' ? 'background: var(--odfe-glass-bg-hover)' : ''">Paid</button>
                        <button t-on-click="() => filterOrders('cancelled')" class="odfe-btn odfe-btn--outline" t-att-style="state.activeFilter === 'cancelled' ? 'background: var(--odfe-glass-bg-hover)' : ''">Cancelled</button>
                    </div>
                    <div style="display: grid; gap: 16px;" t-if="state.filteredOrders.length > 0">
                        <div t-foreach="state.filteredOrders" t-as="order" class="odfe-card" t-on-click="() => openOrder(order)" style="cursor: pointer; background: rgba(0,0,0,0.1);">
                            <div class="odfe-card__body" style="display: flex; justify-content: space-between; align-items: center;">
                                <div>
                                    <div style="font-weight: 600;"><t t-out="order.name"/></div>
                                    <div style="font-size: 12px; color: var(--odfe-text-secondary);"><t t-out="order.ordered_at"/></div>
                                </div>
                                <div style="text-align: right;">
                                    <div style="font-weight: 700; color: var(--odfe-primary); margin-bottom: 4px;"><t t-esc="order.total"/></div>
                                    <span class="odfe-badge odfe-badge--success"><t t-out="order.state"/></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="odfe-pos-empty-cart" t-else="">
                        <p>No orders found</p>
                    </div>
                </div>
            </div>
        </div>
    </template>
    
    <template id="OrderDetail" name="odfe_pos.OrderDetail">
        <div class="odfe-pos" style="padding: var(--odfe-space-6);">
            <div class="odfe-card">
                <div class="odfe-card__header" style="display: flex; gap: 16px; align-items: center;">
                    <button class="odfe-btn odfe-btn--outline" t-on-click="() => props.onBack()"><i class="fa fa-arrow-left"/></button>
                    <h2 class="odfe-card__title" style="flex: 1;"><t t-out="props.order.name"/></h2>
                    <span class="odfe-badge odfe-badge--info"><t t-out="props.order.state"/></span>
                </div>
                <div class="odfe-card__body">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; padding: 16px; background: rgba(0,0,0,0.1); border-radius: 12px;">
                        <div>
                            <div style="font-size: 12px; color: var(--odfe-text-secondary);">Table</div>
                            <div style="font-weight: 600;"><t t-if="props.order.table_name"><t t-out="props.order.table_name"/></t><t t-else="">Takeaway</t></div>
                        </div>
                        <div>
                            <div style="font-size: 12px; color: var(--odfe-text-secondary);">Customer</div>
                            <div style="font-weight: 600;"><t t-if="props.order.customer_name"><t t-out="props.order.customer_name"/></t><t t-else="">Walk-in</t></div>
                        </div>
                    </div>
                     <div t-foreach="props.order.lines" t-as="line" class="odfe-cart-item">
                        <div class="odfe-cart-item__info">
                            <div class="odfe-cart-item__name"><t t-out="line.product_name"/></div>
                            <div class="odfe-cart-item__price"><t t-out="line.quantity"/> x <t t-esc="line.price_unit"/></div>
                        </div>
                        <span class="odfe-cart-item__subtotal"><t t-esc="line.subtotal"/></span>
                    </div>
                    <div class="odfe-pos-summary">
                        <div class="odfe-pos-summary__row">
                            <span>Subtotal</span>
                            <span class="odfe-pos-summary__row-value"><t t-esc="props.order.subtotal"/></span>
                        </div>
                        <div class="odfe-pos-summary__row">
                            <span>Tax</span>
                            <span class="odfe-pos-summary__row-value"><t t-esc="props.order.tax_amount"/></span>
                        </div>
                        <div class="odfe-pos-summary__row" t-if="props.order.discount_total > 0">
                            <span>Discount</span>
                            <span class="odfe-pos-summary__row-value" style="color: var(--odfe-danger);"> -<t t-esc="props.order.discount_total"/></span>
                        </div>
                        <div class="odfe-pos-summary__total">
                            <span class="odfe-pos-summary__total-label">Total</span>
                            <span class="odfe-pos-summary__total-value"><t t-esc="props.order.total"/></span>
                        </div>
                    </div>
                    <div style="margin-top: 24px; display: flex; gap: 8px;">
                        <button class="odfe-btn odfe-btn--primary" t-on-click="() => props.onPrint(props.order)">
                            <i class="fa fa-print" style="margin-right: 8px;"/> Print Receipt
                        </button>
                        <button class="odfe-btn odfe-btn--success" t-if="props.order.state === 'paid'" t-on-click="() => props.onRefund(props.order)">
                            <i class="fa fa-undo" style="margin-right: 8px;"/> Refund
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </template>
    
    <template id="CustomerScreen" name="odfe_pos.CustomerScreen">
        <div class="odfe-pos" style="padding: var(--odfe-space-6);">
            <div class="odfe-card">
                <div class="odfe-card__header" style="display: flex; justify-content: space-between; align-items: center;">
                    <h2 class="odfe-card__title">Customers</h2>
                    <input type="text" class="odfe-input" style="max-width: 300px;" t-model="state.searchQuery" t-on-input="searchCustomers" placeholder="Search..."/>
                </div>
                <div class="odfe-card__body" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 16px;">
                    <div t-foreach="state.customers" t-as="customer" class="odfe-card" t-on-click="() => selectCustomer(customer)" style="cursor: pointer;">
                        <div class="odfe-card__body" style="display: flex; align-items: center; gap: 16px;">
                            <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--odfe-primary-light); color: var(--odfe-primary); display: flex; align-items: center; justify-content: center; font-size: 20px;">
                                <i class="fa fa-user"/>
                            </div>
                            <div>
                                <div style="font-weight: 600;"><t t-out="customer.name"/></div>
                                <div style="font-size: 12px; color: var(--odfe-text-secondary);"><t t-out="customer.phone"/></div>
                            </div>
                        </div>
                    </div>
                    <div t-if="state.customers.length === 0" style="grid-column: 1 / -1; padding: 40px; text-align: center; color: var(--odfe-text-tertiary);">
                        Type to search customers
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="PaymentScreen" name="odfe_pos.PaymentScreen">
        <div class="odfe-pos" style="padding: var(--odfe-space-6);">
            <div class="odfe-card" style="max-width: 600px; margin: 0 auto;">
                <div class="odfe-card__header" style="display: flex; justify-content: space-between; align-items: center;">
                    <div style="display: flex; align-items: center; gap: 16px;">
                        <button class="odfe-btn odfe-btn--outline" t-on-click="() => props.onBack()"><i class="fa fa-arrow-left"/></button>
                        <h2 class="odfe-card__title">Payment</h2>
                    </div>
                    <span style="font-size: 24px; font-weight: 800; color: var(--odfe-primary);"><t t-esc="props.total"/></span>
                </div>
                <div class="odfe-card__body">
                    <div class="odfe-pos-payment-row">
                        <div t-foreach="state.paymentMethods" t-as="method" class="odfe-pay-btn"
                            t-att-class="method.type === 'cash' ? 'odfe-pay-btn--cash' : (method.type === 'card' ? 'odfe-pay-btn--card' : 'odfe-pay-btn--upi')"
                            t-on-click="() => selectMethod(method)" style="cursor: pointer; border: 2px solid transparent;" t-att-style="state.selectedMethod and state.selectedMethod.id === method.id ? 'border-color: currentColor' : ''">
                            <i t-att-class="'fa ' + (method.icon or 'fa-credit-card') + ' odfe-pay-btn__icon'"/>
                            <span><t t-out="method.name"/></span>
                        </div>
                    </div>
                    <div t-if="state.selectedMethod" style="margin-top: 24px;">
                        <label style="display: block; margin-bottom: 8px; font-size: 14px; font-weight: 500; color: var(--odfe-text-secondary);">Amount</label>
                        <input type="number" class="odfe-input" style="height: 56px; font-size: 20px; font-weight: 600;" t-model="state.amount" step="0.01"/>
                        <button class="odfe-btn odfe-btn--primary" style="width: 100%; margin-top: 16px; height: 56px;" t-on-click="processPayment" t-att-disabled="state.amount &lt;= 0">
                            Add Payment <t t-esc="state.amount"/>
                        </button>
                    </div>
                    <hr style="border-color: var(--odfe-glass-border); margin: 24px 0; border-style: solid; border-width: 1px 0 0 0;"/>
                    <div class="odfe-pos-summary">
                        <div class="odfe-pos-summary__row"><span>Total</span><span class="odfe-pos-summary__row-value"><t t-esc="props.total"/></span></div>
                        <div class="odfe-pos-summary__row"><span>Paid</span><span class="odfe-pos-summary__row-value"><t t-esc="state.amountPaid"/></span></div>
                        <div class="odfe-pos-summary__row" style="font-weight: 700; color: var(--odfe-warning);">
                            <span>Remaining</span><span class="odfe-pos-summary__row-value"><t t-esc="props.total - state.amountPaid"/></span>
                        </div>
                    </div>
                    <button class="odfe-btn odfe-btn--success" style="width: 100%; margin-top: 24px; height: 56px; font-size: 16px;" t-on-click="completePayment" t-att-disabled="state.amountPaid &lt; props.total">
                        <i class="fa fa-check-circle" style="margin-right: 8px;"/> Complete Order
                    </button>
                </div>
            </div>
        </div>
    </template>
    
    <template id="ReceiptScreen" name="odfe_pos.ReceiptScreen">
        <div class="odfe-pos" style="padding: var(--odfe-space-6);">
            <div class="odfe-card" style="max-width: 420px; margin: 0 auto;">
                <div class="odfe-card__body text-center" style="padding: 32px;">
                    <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--odfe-success-light); color: var(--odfe-success); display: flex; align-items: center; justify-content: center; font-size: 32px; margin: 0 auto 24px;">
                        <i class="fa fa-check"/>
                    </div>
                    <h2 style="font-size: 24px; font-weight: 800; margin-bottom: 8px;">Order Complete</h2>
                    <p style="color: var(--odfe-text-secondary); margin-bottom: 24px;">Receipt #<t t-out="state.receiptNumber"/></p>
                    
                    <div style="background: rgba(0,0,0,0.1); border-radius: 12px; padding: 16px; margin-bottom: 24px; text-align: left;">
                        <p style="color: var(--odfe-text-tertiary); font-size: 12px; margin-bottom: 12px;"><t t-out="new Date(state.order.ordered_at).toLocaleString()"/></p>
                        <div t-foreach="state.order.lines" t-as="line" style="display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 8px;">
                            <span><t t-out="line.quantity"/> x <t t-out="line.product_name"/></span>
                            <span style="font-family: monospace;"><t t-esc="line.subtotal"/></span>
                        </div>
                        <hr style="border-color: var(--odfe-glass-border); margin: 12px 0; border-style: dashed;"/>
                        <div style="display: flex; justify-content: space-between; font-weight: 700; font-size: 18px;">
                            <span>Total</span>
                            <span style="font-family: monospace; color: var(--odfe-primary);"><t t-esc="state.order.total"/></span>
                        </div>
                    </div>

                    <div style="display: flex; gap: 8px; justify-content: center;">
                        <button class="odfe-btn odfe-btn--outline" t-on-click="printReceipt" style="flex: 1;"><i class="fa fa-print" style="margin-right: 8px;"/> Print</button>
                        <button class="odfe-btn odfe-btn--primary" t-on-click="newOrder" style="flex: 1;">New Order</button>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="DiscountPopup" name="odfe_pos.DiscountPopup">
        <div class="odfe-modal__overlay" t-on-click="close">
            <div class="odfe-modal__content" t-on-click.stop="">
                <div class="odfe-modal__header">
                    <h2 class="odfe-modal__title">Add Discount</h2>
                    <button class="odfe-modal__close" t-on-click="close"><i class="fa fa-times"/></button>
                </div>
                <div class="odfe-modal__body">
                    <div style="margin-bottom: 16px;">
                        <label style="display: block; margin-bottom: 8px; font-size: 14px; font-weight: 500; color: var(--odfe-text-secondary);">Discount Type</label>
                        <select class="odfe-input" t-model="state.discountType">
                            <option value="percentage">Percentage (%)</option>
                            <option value="fixed">Fixed Amount</option>
                        </select>
                    </div>
                    <div style="margin-bottom: 24px;">
                        <label style="display: block; margin-bottom: 8px; font-size: 14px; font-weight: 500; color: var(--odfe-text-secondary);">Value</label>
                        <input type="number" class="odfe-input" t-model="state.discountValue" step="0.01" min="0"/>
                    </div>
                    <button class="odfe-btn odfe-btn--primary" style="width: 100%; height: 48px;" t-on-click="applyDiscount">Apply Discount</button>
                </div>
            </div>
        </div>
    </template>

    <template id="TableView" name="odfe_pos.TableView">
        <div class="odfe-pos" style="padding: var(--odfe-space-6);">
            <div class="odfe-card" style="min-height: 100%;">
                <div class="odfe-card__header">
                    <h2 class="odfe-card__title">Table Management</h2>
                </div>
                <div class="odfe-card__body">
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 16px;">
                        <div t-foreach="state.tables" t-as="table" class="odfe-card" 
                            t-att-style="table.id === state.selectedTableId ? 'border: 2px solid var(--odfe-primary)' : 'border: 2px solid transparent'"
                            t-on-click="() => selectTable(table)" style="cursor: pointer; text-align: center; transition: all 0.2s;">
                            <div class="odfe-card__body">
                                <div style="font-size: 32px; font-weight: 800; color: var(--odfe-primary);"><t t-out="table.name"/></div>
                                <div style="display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; margin-top: 12px;"
                                     t-att-style="table.status === 'occupied' ? 'background: var(--odfe-danger-light); color: var(--odfe-danger);' : 'background: var(--odfe-success-light); color: var(--odfe-success);'">
                                    <t t-out="table.status"/>
                                </div>
                                <div style="font-size: 12px; color: var(--odfe-text-tertiary); margin-top: 12px;"><i class="fa fa-users"/> <t t-out="table.capacity"/> Seats</div>
                            </div>
                        </div>
                    </div>
                    <div t-if="state.tables.length === 0" style="padding: 60px; text-align: center; color: var(--odfe-text-tertiary);">
                        <i class="fa fa-building" style="font-size: 48px; margin-bottom: 16px; opacity: 0.5;"/>
                        <p>No tables available for this floor.</p>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="SessionClose" name="odfe_pos.SessionClose">
        <div class="odfe-pos" style="padding: var(--odfe-space-6);">
            <div class="odfe-card" style="max-width: 500px; margin: 0 auto;">
                <div class="odfe-card__header">
                    <h2 class="odfe-card__title">Close Session</h2>
                    <p style="color: var(--odfe-text-secondary); font-size: 14px; margin-top: 4px;">Session: <t t-out="props.session.name"/></p>
                </div>
                <div class="odfe-card__body">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
                        <div style="background: rgba(0,0,0,0.1); padding: 16px; border-radius: 12px; text-align: center;">
                            <div style="font-size: 12px; color: var(--odfe-text-secondary); margin-bottom: 4px;">Total Orders</div>
                            <div style="font-size: 24px; font-weight: 700; color: var(--odfe-primary);"><t t-esc="props.session.total_orders"/></div>
                        </div>
                        <div style="background: rgba(0,0,0,0.1); padding: 16px; border-radius: 12px; text-align: center;">
                            <div style="font-size: 12px; color: var(--odfe-text-secondary); margin-bottom: 4px;">Total Sales</div>
                            <div style="font-size: 24px; font-weight: 700; color: var(--odfe-primary);"><t t-esc="props.session.total_sales"/></div>
                        </div>
                    </div>
                    
                    <div style="margin-bottom: 24px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 16px;">
                            <span style="color: var(--odfe-text-secondary);">Starting Cash</span>
                            <span style="font-family: monospace; font-weight: 600;"><t t-esc="props.session.start_cash"/></span>
                        </div>
                        <label style="display: block; margin-bottom: 8px; font-size: 14px; font-weight: 500; color: var(--odfe-text-secondary);">Count Ending Cash</label>
                        <input type="number" class="odfe-input" t-model="state.cashCount" step="0.01" style="height: 48px;"/>
                    </div>

                    <div t-if="state.cashCount > 0" style="background: var(--odfe-glass-bg); padding: 16px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; border: 1px solid var(--odfe-glass-border);">
                        <span>Difference:</span>
                        <span t-att-style="(state.cashCount - props.session.total_sales) >= 0 ? 'color: var(--odfe-success); font-weight: 700;' : 'color: var(--odfe-danger); font-weight: 700;'">
                            <t t-esc="state.cashCount - props.session.total_sales"/>
                        </span>
                    </div>

                    <div style="display: flex; gap: 12px;">
                        <button class="odfe-btn odfe-btn--outline" style="flex: 1; height: 48px;" t-on-click="() => props.onCancel()">Cancel</button>
                        <button class="odfe-btn odfe-btn--danger" style="flex: 1; height: 48px;" t-on-click="closeSession" t-att-disabled="state.cashCount &lt;= 0">
                            <i class="fa fa-lock" style="margin-right: 8px;"/> Close Session
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="ReportsScreen" name="odfe_pos.ReportsScreen">
        <div class="odfe-pos" style="padding: var(--odfe-space-6);">
            <h2 style="font-size: 28px; font-weight: 800; margin-bottom: 24px;">Analytics &amp; Reports</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 24px;">
                <div class="odfe-card" style="cursor: pointer; transition: transform 0.2s; background: linear-gradient(135deg, rgba(15,118,110,0.1), rgba(0,0,0,0));" t-on-click="openSalesReport" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='translateY(0)'">
                    <div class="odfe-card__body">
                        <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--odfe-primary); color: white; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 16px; box-shadow: 0 4px 12px rgba(15,118,110,0.3);">
                            <i class="fa fa-line-chart"/>
                        </div>
                        <div style="font-weight: 700; font-size: 18px; margin-bottom: 4px;">Sales Report</div>
                        <div style="font-size: 13px; color: var(--odfe-text-secondary);">Daily, weekly, monthly sales overview</div>
                    </div>
                </div>
                
                <div class="odfe-card" style="cursor: pointer; transition: transform 0.2s; background: linear-gradient(135deg, rgba(212,163,115,0.1), rgba(0,0,0,0));" t-on-click="openPaymentReport" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='translateY(0)'">
                    <div class="odfe-card__body">
                        <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--odfe-accent); color: white; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 16px; box-shadow: 0 4px 12px rgba(212,163,115,0.3);">
                            <i class="fa fa-credit-card"/>
                        </div>
                        <div style="font-weight: 700; font-size: 18px; margin-bottom: 4px;">Payment Summary</div>
                        <div style="font-size: 13px; color: var(--odfe-text-secondary);">Payment methods breakdown</div>
                    </div>
                </div>

                <div class="odfe-card" style="cursor: pointer; transition: transform 0.2s; background: linear-gradient(135deg, rgba(34,197,94,0.1), rgba(0,0,0,0));" t-on-click="openProductReport" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='translateY(0)'">
                    <div class="odfe-card__body">
                        <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--odfe-success); color: white; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 16px; box-shadow: 0 4px 12px rgba(34,197,94,0.3);">
                            <i class="fa fa-shopping-cart"/>
                        </div>
                        <div style="font-weight: 700; font-size: 18px; margin-bottom: 4px;">Product Report</div>
                        <div style="font-size: 13px; color: var(--odfe-text-secondary);">Best selling products &amp; inventory</div>
                    </div>
                </div>

                <div class="odfe-card" style="cursor: pointer; transition: transform 0.2s; background: linear-gradient(135deg, rgba(56,189,248,0.1), rgba(0,0,0,0));" t-on-click="openSessionReport" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='translateY(0)'">
                    <div class="odfe-card__body">
                        <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--odfe-info); color: white; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 16px; box-shadow: 0 4px 12px rgba(56,189,248,0.3);">
                            <i class="fa fa-history"/>
                        </div>
                        <div style="font-weight: 700; font-size: 18px; margin-bottom: 4px;">Session History</div>
                        <div style="font-size: 13px; color: var(--odfe-text-secondary);">All sessions &amp; cashier overview</div>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="ProductCard" name="odfe_pos.ProductCard">
        <div class="odfe-product" t-on-click="() => props.onSelect(props.product)">
            <div class="odfe-product__image">
                <img t-if="props.product.image_url" t-att-src="props.product.image_url" t-att-alt="props.product.name"/>
                <div t-else="" class="odfe-product__image-placeholder"><i class="fa fa-picture-o"/></div>
                <div class="odfe-product__badge" t-if="props.product.qty_available"><t t-out="props.product.qty_available"/></div>
            </div>
            <div class="odfe-product__body">
                <div class="odfe-product__name"><t t-out="props.product.name"/></div>
                <div class="odfe-product__category" t-if="props.product.category_name"><t t-out="props.product.category_name"/></div>
                <div class="odfe-product__price"><t t-esc="props.product.price"/></div>
            </div>
        </div>
    </template>

    <template id="CategoryTabs" name="odfe_pos.CategoryTabs">
        <div class="odfe-pos-categories">
            <button t-foreach="state.categories" t-as="cat" class="odfe-pos-categories__pill"
                t-att-class="cat.id === state.activeCategoryId ? 'active' : ''"
                t-on-click="() => selectCategory(cat)">
                <t t-out="cat.name"/>
            </button>
        </div>
    </template>

    <template id="CartComponent" name="odfe_pos.CartComponent">
        <div class="odfe-pos-cart-panel" style="height: 100%;">
            <div class="odfe-pos-cart-header">
                <div class="odfe-pos-cart-header__title">
                    Order <span class="odfe-pos-cart-header__count" t-if="state.lines.length"><t t-out="state.lines.length"/></span>
                </div>
                <button class="odfe-btn odfe-btn--outline" style="padding: 4px 8px; font-size: 12px;" t-on-click="clearCart" t-if="state.lines.length > 0">Clear</button>
            </div>
            <div class="odfe-pos-cart-items" t-if="state.lines.length > 0">
                <CartItem t-foreach="state.lines" t-as="line" t-key="line.id"
                    line="line" onUpdate="updateLine" onRemove="removeLine"/>
            </div>
            <div class="odfe-pos-empty-cart" t-else="">
                <i class="fa fa-shopping-basket odfe-pos-empty-cart__icon"/>
                <div class="odfe-pos-empty-cart__text">Cart is empty</div>
            </div>
            <div class="odfe-pos-summary" t-if="state.lines.length > 0">
                <div class="odfe-pos-summary__row">
                    <span>Subtotal</span>
                    <span class="odfe-pos-summary__row-value"><t t-esc="state.subtotal"/></span>
                </div>
                <div class="odfe-pos-summary__row odfe-pos-summary__coupon" t-if="state.discountTotal > 0">
                    <span>Discount</span>
                    <span class="odfe-pos-summary__coupon-value">-<t t-esc="state.discountTotal"/></span>
                </div>
                <div class="odfe-pos-summary__total">
                    <span class="odfe-pos-summary__total-label">Total</span>
                    <span class="odfe-pos-summary__total-value"><t t-esc="state.total"/></span>
                </div>
            </div>
            <div class="odfe-pos-payment-row" t-if="state.lines.length > 0">
                 <!-- Actions -->
                 <button class="odfe-action-btn" t-on-click="() => props.onDiscount()">
                     <i class="fa fa-tag"/> Discount
                 </button>
                 <button class="odfe-action-btn" t-on-click="() => props.onCustomer()">
                     <i class="fa fa-user"/> Customer
                 </button>
                 <button class="odfe-action-btn odfe-action-btn--kitchen" t-on-click="placeOrder" style="grid-column: span 3; margin-top: 8px;">
                     <i class="fa fa-check"/> Pay Now
                 </button>
            </div>
        </div>
    </template>

    <template id="CartItem" name="odfe_pos.CartItem">
        <div class="odfe-cart-item">
            <div class="odfe-cart-item__info">
                <div class="odfe-cart-item__name"><t t-out="props.line.product_name"/></div>
                <div class="odfe-cart-item__price"><t t-esc="props.line.price_unit"/></div>
            </div>
            <div class="odfe-cart-item__controls">
                <button class="odfe-cart-item__qty-btn" t-on-click="() => props.onUpdate(props.line.id, props.line.quantity - 1)">-</button>
                <span class="odfe-cart-item__qty"><t t-out="props.line.quantity"/></span>
                <button class="odfe-cart-item__qty-btn" t-on-click="() => props.onUpdate(props.line.id, props.line.quantity + 1)">+</button>
            </div>
            <div class="odfe-cart-item__subtotal"><t t-esc="props.line.subtotal"/></div>
            <button class="odfe-cart-item__remove" t-on-click="() => props.onRemove(props.line.id)">
                <i class="fa fa-times"/>
            </button>
        </div>
    </template>

    <template id="OrderSummary" name="odfe_pos.OrderSummary">
        <div class="odfe-pos-summary">
            <div t-foreach="props.order.lines" t-as="line" class="odfe-pos-summary__row">
                <span><t t-out="line.quantity"/>x <t t-out="line.product_name"/></span>
                <span class="odfe-pos-summary__row-value"><t t-esc="line.subtotal"/></span>
            </div>
            <div class="odfe-pos-summary__total">
                <span class="odfe-pos-summary__total-label">Total</span>
                <span class="odfe-pos-summary__total-value"><t t-esc="props.order.total"/></span>
            </div>
        </div>
    </template>

    <template id="PaymentButton" name="odfe_pos.PaymentButton">
        <button class="odfe-pay-btn" t-att-class="props.method.type === 'cash' ? 'odfe-pay-btn--cash' : (props.method.type === 'card' ? 'odfe-pay-btn--card' : 'odfe-pay-btn--upi')"
            t-on-click="() => props.onSelect(props.method)">
            <i t-att-class="'fa ' + (props.method.icon or 'fa-credit-card') + ' odfe-pay-btn__icon'"/>
            <span><t t-out="props.method.name"/></span>
        </button>
    </template>

    <template id="SearchBar" name="odfe_pos.SearchBar">
        <div class="odfe-pos-search" style="width: 100%;">
            <i class="fa fa-search odfe-pos-search__icon"/>
            <input type="text" class="odfe-pos-search__input" t-model="state.query" t-on-input="onSearch" placeholder="Search products..."/>
            <button class="odfe-pos-search__clear" t-if="state.query" t-on-click="clearSearch"><i class="fa fa-times"/></button>
        </div>
    </template>

    <template id="Navbar" name="odfe_pos.Navbar">
        <nav class="odfe-pos-nav">
            <div class="odfe-pos-nav__brand">
                <div class="odfe-pos-nav__brand-icon">O</div>
                <span class="odfe-pos-nav__brand-name">ODFE POS</span>
            </div>
            <div class="odfe-pos-nav__center">
                <div class="odfe-pos-nav__info" t-on-click="() => props.onFloor()" style="cursor: pointer;">
                    <i class="fa fa-building"/>
                    <strong t-if="props.currentFloor"><t t-out="props.currentFloor.name"/></strong>
                    <strong t-else="">Select Floor</strong>
                </div>
            </div>
            <div class="odfe-pos-nav__actions">
                <button class="odfe-pos-nav__btn" t-on-click="() => props.onOrders()">
                    <i class="fa fa-list"/>
                    <span t-if="props.pendingOrders" class="odfe-pos-nav__btn-badge"><t t-esc="props.pendingOrders"/></span>
                </button>
                <button class="odfe-pos-nav__btn" t-on-click="() => props.onSession()">
                    <i class="fa fa-cog"/>
                </button>
            </div>
        </nav>
    </template>

    <template id="CustomerCard" name="odfe_pos.CustomerCard">
        <!-- Merged into CustomerScreen -->
    </template>

    <template id="TableCard" name="odfe_pos.TableCard">
        <!-- Merged into TableView -->
    </template>

    <template id="FloorSelector" name="odfe_pos.FloorSelector">
        <!-- Merged into FloorPopup -->
    </template>

    <template id="ReceiptPreview" name="odfe_pos.ReceiptPreview">
        <div class="odfe-card">
            <div class="odfe-card__body" t-if="props.receipt">
                <t t-raw="props.receipt.content_html"/>
            </div>
            <div class="odfe-card__body text-center text-muted" t-else="">
                No receipt data
            </div>
        </div>
    </template>

    <template id="QrPayment" name="odfe_pos.QrPayment">
        <div class="odfe-card text-center" style="max-width: 300px; margin: 0 auto;">
            <div class="odfe-card__header">
                <h3 class="odfe-card__title">Scan to Pay</h3>
            </div>
            <div class="odfe-card__body">
                <div style="background: white; padding: 16px; border-radius: 12px; display: inline-block;">
                    <img t-att-src="state.qrData" t-if="state.qrData" alt="QR Code" style="width: 200px; height: 200px;"/>
                    <div t-else="" style="width: 200px; height: 200px; display: flex; align-items: center; justify-content: center; background: #f0f0f0; border-radius: 8px;">
                        <i class="fa fa-qrcode" style="font-size: 48px; color: #ccc;"/>
                    </div>
                </div>
                <div style="font-size: 24px; font-weight: 800; color: var(--odfe-primary); margin-top: 16px;">
                    <t t-esc="props.amount"/>
                </div>
            </div>
        </div>
    </template>
</odoo>

