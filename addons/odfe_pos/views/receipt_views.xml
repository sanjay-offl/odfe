<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_receipt_tree" model="ir.ui.view">
        <field name="name">odfe.pos.receipt.tree</field>
        <field name="model">odfe.pos.receipt</field>
        <field name="arch" type="xml">
            <tree string="Receipts" default_order="id desc">
                <field name="receipt_number"/>
                <field name="order_id"/>
                <field name="printed"/>
                <field name="emailed"/>
                <field name="printed_at"/>
                <field name="emailed_at"/>
                <field name="emailed_to"/>
            </tree>
        </field>
    </record>

    <record id="view_pos_receipt_form" model="ir.ui.view">
        <field name="name">odfe.pos.receipt.form</field>
        <field name="model">odfe.pos.receipt</field>
        <field name="arch" type="xml">
            <form string="Receipt">
                <sheet>
                    <group>
                        <group>
                            <field name="receipt_number"/>
                            <field name="order_id"/>
                        </group>
                        <group>
                            <field name="printed"/>
                            <field name="emailed"/>
                            <field name="emailed_to"/>
                        </group>
                    </group>
                    <group>
                        <field name="printed_at"/>
                        <field name="emailed_at"/>
                    </group>
                    <field name="content_html" readonly="1" nolabel="1"/>
                    <field name="receipt_data" readonly="1" nolabel="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pos_receipt" model="ir.actions.act_window">
        <field name="name">Receipts</field>
        <field name="res_model">odfe.pos.receipt</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'default_order_id': active_id}</field>
    </record>
</odoo>
