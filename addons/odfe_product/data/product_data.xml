<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <!-- Default Categories -->
    <record id="category_starters" model="odfe.product.category">
      <field name="name">Starters</field>
      <field name="sequence">10</field>
      <field name="pos_visible" eval="True"/>
      <field name="color">1</field>
    </record>

    <record id="category_main_course" model="odfe.product.category">
      <field name="name">Main Course</field>
      <field name="sequence">20</field>
      <field name="pos_visible" eval="True"/>
      <field name="color">2</field>
    </record>

    <record id="category_desserts" model="odfe.product.category">
      <field name="name">Desserts</field>
      <field name="sequence">30</field>
      <field name="pos_visible" eval="True"/>
      <field name="color">3</field>
    </record>

    <record id="category_beverages" model="odfe.product.category">
      <field name="name">Beverages</field>
      <field name="sequence">40</field>
      <field name="pos_visible" eval="True"/>
      <field name="color">4</field>
    </record>

    <record id="category_sides" model="odfe.product.category">
      <field name="name">Sides</field>
      <field name="sequence">50</field>
      <field name="pos_visible" eval="True"/>
      <field name="color">5</field>
    </record>

    <record id="category_soups" model="odfe.product.category">
      <field name="name">Soups</field>
      <field name="sequence">60</field>
      <field name="pos_visible" eval="True"/>
      <field name="color">6</field>
    </record>

    <record id="category_salads" model="odfe.product.category">
      <field name="name">Salads</field>
      <field name="sequence">70</field>
      <field name="pos_visible" eval="True"/>
      <field name="color">7</field>
    </record>

    <record id="category_breakfast" model="odfe.product.category">
      <field name="name">Breakfast</field>
      <field name="sequence">5</field>
      <field name="pos_visible" eval="True"/>
      <field name="color">8</field>
    </record>

    <record id="category_alcohol" model="odfe.product.category">
      <field name="name">Alcohol</field>
      <field name="sequence">45</field>
      <field name="pos_visible" eval="True"/>
      <field name="color">9</field>
    </record>

    <record id="category_combos" model="odfe.product.category">
      <field name="name">Combos &amp; Offers</field>
      <field name="sequence">80</field>
      <field name="pos_visible" eval="True"/>
      <field name="color">10</field>
    </record>

    <!-- Default Tax Rates -->
    <record id="tax_gst_5" model="odfe.product.tax">
      <field name="name">GST 5%</field>
      <field name="type">percentage</field>
      <field name="percentage">5.0</field>
      <field name="included_in_price" eval="True"/>
      <field name="applicable_on">all</field>
      <field name="sequence">10</field>
      <field name="active" eval="True"/>
    </record>

    <record id="tax_gst_12" model="odfe.product.tax">
      <field name="name">GST 12%</field>
      <field name="type">percentage</field>
      <field name="percentage">12.0</field>
      <field name="included_in_price" eval="True"/>
      <field name="applicable_on">all</field>
      <field name="sequence">20</field>
      <field name="active" eval="True"/>
    </record>

    <record id="tax_gst_18" model="odfe.product.tax">
      <field name="name">GST 18%</field>
      <field name="type">percentage</field>
      <field name="percentage">18.0</field>
      <field name="included_in_price" eval="True"/>
      <field name="applicable_on">all</field>
      <field name="sequence">30</field>
      <field name="active" eval="True"/>
    </record>

    <record id="tax_gst_28" model="odfe.product.tax">
      <field name="name">GST 28%</field>
      <field name="type">percentage</field>
      <field name="percentage">28.0</field>
      <field name="included_in_price" eval="True"/>
      <field name="applicable_on">all</field>
      <field name="sequence">40</field>
      <field name="active" eval="True"/>
    </record>

    <record id="tax_no_tax" model="odfe.product.tax">
      <field name="name">No Tax</field>
      <field name="type">percentage</field>
      <field name="percentage">0.0</field>
      <field name="included_in_price" eval="False"/>
      <field name="applicable_on">all</field>
      <field name="sequence">0</field>
      <field name="active" eval="True"/>
    </record>

    <record id="tax_service_charge" model="odfe.product.tax">
      <field name="name">Service Charge 10%</field>
      <field name="type">percentage</field>
      <field name="percentage">10.0</field>
      <field name="included_in_price" eval="False"/>
      <field name="applicable_on">all</field>
      <field name="sequence">50</field>
      <field name="active" eval="True"/>
    </record>
  </data>
</odoo>
