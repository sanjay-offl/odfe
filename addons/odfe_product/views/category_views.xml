<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_odfe_product_category_tree" model="ir.ui.view">
    <field name="name">odfe.product.category.tree</field>
    <field name="model">odfe.product.category</field>
    <field name="arch" type="xml">
      <tree decoration-success="pos_visible==True" decoration-muted="pos_visible==False">
        <field name="image" widget="image" class="oe_avatar" options="{'size': [32, 32]}"/>
        <field name="display_name" string="Name"/>
        <field name="sequence" string="Seq"/>
        <field name="pos_visible" string="POS" widget="boolean_toggle"/>
        <field name="color" string="Color" widget="color"/>
      </tree>
    </field>
  </record>

  <record id="view_odfe_product_category_form" model="ir.ui.view">
    <field name="name">odfe.product.category.form</field>
    <field name="model">odfe.product.category</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <widget name="web_ribbon" text="Hidden in POS" bg_color="bg-danger" invisible="pos_visible"/>
          <field name="image" widget="image" class="oe_avatar"/>
          <div class="oe_title">
            <label for="name"/>
            <h1><field name="name"/></h1>
          </div>
          <group>
            <group string="General">
              <field name="parent_id" options="{'no_create': True}"/>
              <field name="sequence"/>
              <field name="pos_visible"/>
              <field name="color" widget="color"/>
            </group>
          </group>
          <notebook>
            <page string="Products">
              <field name="product_ids" nolabel="1">
                <tree>
                  <field name="display_name"/>
                  <field name="list_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                  <field name="pos_visible"/>
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_odfe_product_category" model="ir.actions.act_window">
    <field name="name">Categories</field>
    <field name="res_model">odfe.product.category</field>
    <field name="view_mode">tree,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Create your first ODFE product category</p>
      <p>Organize products into categories for easier navigation in the POS.</p>
    </field>
  </record>
</odoo>
