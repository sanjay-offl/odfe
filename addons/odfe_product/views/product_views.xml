<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_odfe_product_tree" model="ir.ui.view">
    <field name="name">odfe.product.tree</field>
    <field name="model">odfe.product</field>
    <field name="arch" type="xml">
      <tree decoration-success="pos_visible==True" decoration-muted="pos_visible==False">
        <field name="image_128" widget="image" class="oe_avatar" options="{'size': [48, 48]}"/>
        <field name="display_name" string="Name"/>
        <field name="default_code" string="Ref"/>
        <field name="category_id" string="Category"/>
        <field name="list_price" string="Price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
        <field name="preparation_time" string="Prep (min)"/>
        <field name="pos_visible" string="POS" widget="boolean_toggle"/>
        <field name="kds_visible" string="KDS" widget="boolean_toggle"/>
        <field name="modifiers_available" string="Mod" widget="boolean_toggle"/>
        <field name="sequence" string="Seq"/>
      </tree>
    </field>
  </record>

  <record id="view_odfe_product_form" model="ir.ui.view">
    <field name="name">odfe.product.form</field>
    <field name="model">odfe.product</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <div class="oe_button_box" name="button_box">
            <button name="%(product.product_template_action)d" type="action"
                class="oe_stat_button" icon="fa-cubes"
                string="Product Template"/>
          </div>
          <widget name="web_ribbon" text="Hidden in POS" bg_color="bg-danger" invisible="pos_visible"/>
          <field name="image_128" widget="image" class="oe_avatar"/>
          <div class="oe_title">
            <label for="display_name" string="Name"/>
            <h1><field name="display_name" readonly="1"/></h1>
          </div>
          <group>
            <group string="General">
              <field name="product_tmpl_id" options="{'no_create': True}"/>
              <field name="default_code" string="Internal Reference"/>
              <field name="barcode"/>
              <field name="list_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
              <field name="uom_id"/>
            </group>
            <group string="ODFE Settings">
              <field name="category_id" options="{'no_create': True}"/>
              <field name="pos_visible"/>
              <field name="kds_visible"/>
              <field name="preparation_time" string="Preparation Time (min)"/>
              <field name="modifiers_available"/>
              <field name="tax_type" readonly="1"/>
            </group>
          </group>
          <notebook>
            <page string="Taxes">
              <field name="tax_ids" widget="many2many_tags"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_odfe_product_search" model="ir.ui.view">
    <field name="name">odfe.product.search</field>
    <field name="model">odfe.product</field>
    <field name="arch" type="xml">
      <search>
        <field name="display_name" string="Name" filter_domain="[('display_name','ilike',self)]"/>
        <field name="default_code" string="Reference" filter_domain="[('default_code','ilike',self)]"/>
        <field name="barcode" filter_domain="[('barcode','ilike',self)]"/>
        <filter name="pos_visible" string="Visible in POS" domain="[('pos_visible','=',True)]"/>
        <filter name="kds_visible" string="Visible on KDS" domain="[('kds_visible','=',True)]"/>
        <filter name="modifiers" string="Has Modifiers" domain="[('modifiers_available','=',True)]"/>
        <separator/>
        <filter name="group_category" string="Category" context="{'group_by': 'category_id'}"/>
        <searchpanel>
          <field name="category_id" select="multi"/>
          <field name="pos_visible"/>
        </searchpanel>
      </search>
    </field>
  </record>

  <record id="view_odfe_product_kanban" model="ir.ui.view">
    <field name="name">odfe.product.kanban</field>
    <field name="model">odfe.product</field>
    <field name="arch" type="xml">
      <kanban class="o_kanban_mobile" group_create="false">
        <field name="display_name"/>
        <field name="image_128"/>
        <field name="list_price"/>
        <field name="category_id"/>
        <field name="pos_visible"/>
        <field name="preparation_time"/>
        <templates>
          <t t-name="kanban-box">
            <div class="oe_kanban_global_click" t-attf-class="oe_kanban_card {{ pos_visible ? '' : 'oe_kanban_card_disabled' }}">
              <div class="oe_kanban_image">
                <img t-att-src="kanban_image('odfe.product', 'image_128', record.id.raw_value)" alt="Product" class="o_image_64_cover"/>
              </div>
              <div class="oe_kanban_details">
                <strong class="o_kanban_record_title"><field name="display_name"/></strong>
                <div class="text-muted o_kanban_record_subtitle">
                  <field name="category_id"/>
                </div>
                <div class="o_kanban_record_body">
                  <field name="list_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                  <t t-if="record.preparation_time.raw_value">
                    <span class="ms-2 text-muted">
                      <i class="fa fa-clock-o"/> <t t-esc="record.preparation_time.value"/> min
                    </span>
                  </t>
                </div>
              </div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <record id="action_odfe_product" model="ir.actions.act_window">
    <field name="name">Products</field>
    <field name="res_model">odfe.product</field>
    <field name="view_mode">tree,form,kanban</field>
    <field name="search_view_id" ref="view_odfe_product_search"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Add your first ODFE product</p>
      <p>Link products from the Odoo product catalog and configure ODFE-specific settings.</p>
    </field>
  </record>
</odoo>
