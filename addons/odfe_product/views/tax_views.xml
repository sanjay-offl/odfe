<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_odfe_product_tax_tree" model="ir.ui.view">
    <field name="name">odfe.product.tax.tree</field>
    <field name="model">odfe.product.tax</field>
    <field name="arch" type="xml">
      <tree decoration-success="active==True" decoration-muted="active==False">
        <field name="name"/>
        <field name="type"/>
        <field name="percentage" string="%" invisible="type!='percentage'"/>
        <field name="amount" string="Amount" invisible="type!='fixed'"/>
        <field name="included_in_price" string="Included"/>
        <field name="applicable_on" string="Applies To"/>
        <field name="sequence" string="Seq"/>
        <field name="active" string="Active" widget="boolean_toggle"/>
      </tree>
    </field>
  </record>

  <record id="view_odfe_product_tax_form" model="ir.ui.view">
    <field name="name">odfe.product.tax.form</field>
    <field name="model">odfe.product.tax</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <widget name="web_ribbon" text="Inactive" bg_color="bg-danger" invisible="active"/>
          <div class="oe_title">
            <label for="name"/>
            <h1><field name="name"/></h1>
          </div>
          <group>
            <group string="General">
              <field name="type"/>
              <field name="percentage" invisible="type!='percentage'"/>
              <field name="amount" invisible="type!='fixed'"/>
              <field name="included_in_price"/>
              <field name="applicable_on"/>
              <field name="active"/>
              <field name="sequence"/>
            </group>
            <group string="Accounting">
              <field name="account_id"/>
            </group>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_odfe_product_tax" model="ir.actions.act_window">
    <field name="name">Taxes</field>
    <field name="res_model">odfe.product.tax</field>
    <field name="view_mode">tree,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Define your tax rates</p>
      <p>Configure percentage or fixed tax rates applicable to food and beverages.</p>
    </field>
  </record>
</odoo>
