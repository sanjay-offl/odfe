<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odfe_sync_log_tree" model="ir.ui.view">
        <field name="name">odfe.sync.log.tree</field>
        <field name="model">odfe.sync.log</field>
        <field name="arch" type="xml">
            <tree string="Sync Logs" editable="false" default_order="sync_at desc">
                <field name="model_name"/>
                <field name="res_id"/>
                <field name="operation"/>
                <field name="user_id" optional="show"/>
                <field name="status" widget="badge" decoration-success="status == 'synced'" decoration-warning="status == 'pending'" decoration-danger="status == 'failed'"/>
                <field name="sync_at"/>
                <field name="error_message" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_odfe_sync_log_form" model="ir.ui.view">
        <field name="name">odfe.sync.log.form</field>
        <field name="model">odfe.sync.log</field>
        <field name="arch" type="xml">
            <form string="Sync Log">
                <sheet>
                    <group>
                        <group>
                            <field name="model_name"/>
                            <field name="res_id"/>
                            <field name="operation"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="status"/>
                            <field name="sync_at"/>
                        </group>
                    </group>
                    <field name="error_message" nolabel="1" attrs="{'invisible': [('error_message', '=', False)]}"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_odfe_sync_log_search" model="ir.ui.view">
        <field name="name">odfe.sync.log.search</field>
        <field name="model">odfe.sync.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="model_name"/>
                <field name="res_id"/>
                <filter name="pending" string="Pending" domain="[('status','=','pending')]"/>
                <filter name="synced" string="Synced" domain="[('status','=','synced')]"/>
                <filter name="failed" string="Failed" domain="[('status','=','failed')]"/>
                <separator/>
                <filter name="create" string="Create" domain="[('operation','=','create')]"/>
                <filter name="write" string="Write" domain="[('operation','=','write')]"/>
                <filter name="unlink" string="Unlink" domain="[('operation','=','unlink')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_model" string="Model" context="{'group_by':'model_name'}"/>
                    <filter name="group_by_status" string="Status" context="{'group_by':'status'}"/>
                    <filter name="group_by_operation" string="Operation" context="{'group_by':'operation'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_odfe_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">odfe.sync.log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_odfe_sync_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No sync logs yet.
            </p>
        </field>
    </record>
</odoo>
