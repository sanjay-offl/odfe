<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_sales_pdf" name="Sales Report PDF">
        <t t-call="web.html_container">
            <t t-raw="0"/>
        </t>
    </template>

    <template id="report_order_pdf" name="Order Receipt PDF">
        <t t-call="web.html_container">
            <t t-raw="0"/>
        </t>
    </template>

    <template id="report_sales_xlsx" name="Sales Report XLSX">
        <t t-call="web.html_container">
            <t t-raw="0"/>
        </t>
    </template>

    <template id="report_report_pdf" name="Generic Report PDF">
        <t t-call="web.html_container">
            <t t-raw="0"/>
        </t>
    </template>

    <report id="report_action_sales_pdf"
            model="odfe.report.sales"
            string="Sales Report (PDF)"
            report_type="qweb-pdf"
            name="odfe_reports.report_sales_pdf"
            file="odfe_reports.report_sales_pdf"
            print_report_name="'Sales_Report_%s' % (time.strftime('%%Y%%m%%d'))"/>

    <report id="report_action_order_pdf"
            model="odfe.pos.order"
            string="Order Receipt (PDF)"
            report_type="qweb-pdf"
            name="odfe_reports.report_order_pdf"
            file="odfe_reports.report_order_pdf"
            print_report_name="'Order_%s' % (object.name)"/>

    <report id="report_action_sales_xlsx"
            model="odfe.report.sales"
            string="Sales Report (XLSX)"
            report_type="qweb-xlsx"
            name="odfe_reports.report_sales_xlsx"
            file="odfe_reports.report_sales_xlsx"
            print_report_name="'Sales_Report_%s' % (time.strftime('%%Y%%m%%d'))"/>
</odoo>
