<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odfe_report_employees_tree" model="ir.ui.view">
        <field name="name">odfe.report.employees.tree</field>
        <field name="model">odfe.report.employees</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="employee_id"/>
            </tree>
        </field>
    </record>

    <record id="view_odfe_report_employees_form" model="ir.ui.view">
        <field name="name">odfe.report.employees.form</field>
        <field name="model">odfe.report.employees</field>
        <field name="arch" type="xml">
            <form string="Employee Performance Report">
                <group>
                    <field name="date_from" required="1"/>
                    <field name="date_to" required="1"/>
                    <field name="employee_id"/>
                </group>
                <footer>
                    <button name="%(action_odfe_report_employees_results)d" type="action"
                            string="Generate Report" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_odfe_report_employees" model="ir.actions.act_window">
        <field name="name">Employee Performance</field>
        <field name="res_model">odfe.report.employees</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="help" type="html">
            <p>Generate an employee performance report for a specific period.</p>
        </field>
    </record>

    <record id="action_odfe_report_employees_results" model="ir.actions.act_window">
        <field name="name">Employee Performance Results</field>
        <field name="res_model">odfe.report.employees</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
