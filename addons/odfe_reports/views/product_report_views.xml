<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odfe_report_products_tree" model="ir.ui.view">
        <field name="name">odfe.report.products.tree</field>
        <field name="model">odfe.report.products</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="category_id"/>
            </tree>
        </field>
    </record>

    <record id="view_odfe_report_products_form" model="ir.ui.view">
        <field name="name">odfe.report.products.form</field>
        <field name="model">odfe.report.products</field>
        <field name="arch" type="xml">
            <form string="Products Report">
                <group>
                    <field name="date_from" required="1"/>
                    <field name="date_to" required="1"/>
                    <field name="category_id"/>
                    <field name="limit"/>
                </group>
                <footer>
                    <button name="%(action_odfe_report_products_results)d" type="action"
                            string="Generate Report" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_odfe_report_products" model="ir.actions.act_window">
        <field name="name">Products Report</field>
        <field name="res_model">odfe.report.products</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="help" type="html">
            <p>Generate a products report with top sellers and category breakdown.</p>
        </field>
    </record>

    <record id="action_odfe_report_products_results" model="ir.actions.act_window">
        <field name="name">Products Report Results</field>
        <field name="res_model">odfe.report.products</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
