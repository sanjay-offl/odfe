<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odfe_report_revenue_tree" model="ir.ui.view">
        <field name="name">odfe.report.revenue.tree</field>
        <field name="model">odfe.report.revenue</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date_from"/>
                <field name="date_to"/>
            </tree>
        </field>
    </record>

    <record id="view_odfe_report_revenue_form" model="ir.ui.view">
        <field name="name">odfe.report.revenue.form</field>
        <field name="model">odfe.report.revenue</field>
        <field name="arch" type="xml">
            <form string="Revenue Report">
                <group>
                    <field name="date_from" required="1"/>
                    <field name="date_to" required="1"/>
                </group>
                <footer>
                    <button name="%(action_odfe_report_revenue_results)d" type="action"
                            string="Generate Report" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_odfe_report_revenue" model="ir.actions.act_window">
        <field name="name">Revenue Report</field>
        <field name="res_model">odfe.report.revenue</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="help" type="html">
            <p>Generate a revenue report for a specific period.</p>
        </field>
    </record>

    <record id="action_odfe_report_revenue_results" model="ir.actions.act_window">
        <field name="name">Revenue Report Results</field>
        <field name="res_model">odfe.report.revenue</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
