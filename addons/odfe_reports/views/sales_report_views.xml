<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odfe_report_sales_tree" model="ir.ui.view">
        <field name="name">odfe.report.sales.tree</field>
        <field name="model">odfe.report.sales</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="period"/>
                <field name="category_id"/>
                <field name="employee_id"/>
            </tree>
        </field>
    </record>

    <record id="view_odfe_report_sales_form" model="ir.ui.view">
        <field name="name">odfe.report.sales.form</field>
        <field name="model">odfe.report.sales</field>
        <field name="arch" type="xml">
            <form string="Sales Report">
                <group>
                    <group>
                        <field name="date_from" required="1"/>
                        <field name="date_to" required="1"/>
                    </group>
                    <group>
                        <field name="period"/>
                        <field name="category_id"/>
                        <field name="employee_id"/>
                    </group>
                </group>
                <footer>
                    <button name="%(action_odfe_report_sales_results)d" type="action"
                            string="Generate Report" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_odfe_report_sales" model="ir.actions.act_window">
        <field name="name">Sales Report</field>
        <field name="res_model">odfe.report.sales</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="help" type="html">
            <p>Generate a sales report for a specific period.</p>
        </field>
    </record>

    <record id="action_odfe_report_sales_results" model="ir.actions.act_window">
        <field name="name">Sales Report Results</field>
        <field name="res_model">odfe.report.sales</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
