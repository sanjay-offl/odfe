<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="report_self_order_qr" model="ir.actions.report">
            <field name="name">Table QR Codes</field>
            <field name="model">odfe.self.order.qr.table</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">odfe_self_order.report_qr_table</field>
            <field name="print_report_name">'QR_Codes_%s' % (fields.Datetime.now().strftime('%Y%m%d'))</field>
            <field name="binding_model_id" ref="model_odfe_self_order_qr_table"/>
            <field name="binding_type">report</field>
        </record>

        <template id="report_qr_table">
            <t t-call="web.basic_layout">
                <div class="page">
                    <div class="text-center" style="padding: 20px 0;">
                        <h2>Table QR Codes</h2>
                        <p>Scan to self-order</p>
                    </div>
                    <t t-foreach="docs" t-as="doc">
                        <div class="qr-card" style="
                            display: inline-block;
                            width: 45%;
                            margin: 10px;
                            padding: 20px;
                            border: 1px solid #ddd;
                            border-radius: 12px;
                            text-align: center;
                            page-break-inside: avoid;
                        ">
                            <h3 style="margin: 0 0 10px 0; font-size: 18px; color: #333;">
                                <t t-esc="doc.table_id.name"/>
                            </h3>
                            <img t-if="doc.qr_code" t-att-src="'data:image/png;base64,%s' % doc.qr_code.decode()"
                                style="width: 180px; height: 180px; image-rendering: pixelated;"/>
                            <p style="margin-top: 8px; font-size: 11px; color: #888; word-break: break-all;">
                                <t t-esc="doc.qr_token"/>
                            </p>
                        </div>
                    </t>
                </div>
            </t>
        </template>

    </data>
</odoo>
