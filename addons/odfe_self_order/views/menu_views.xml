<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_self_order_menu_tree" model="ir.ui.view">
            <field name="name">odfe.self.order.menu.tree</field>
            <field name="model">odfe.self.order.menu</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="is_active"/>
                    <field name="restaurant_id"/>
                    <field name="sequence"/>
                </tree>
            </field>
        </record>

        <record id="view_self_order_menu_form" model="ir.ui.view">
            <field name="name">odfe.self.order.menu.form</field>
            <field name="model">odfe.self.order.menu</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="active"/>
                                <field name="is_active"/>
                                <field name="restaurant_id"/>
                                <field name="sequence"/>
                            </group>
                            <group>
                                <field name="description"/>
                                <field name="image" widget="image"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="products" string="Products">
                                <field name="product_ids">
                                    <tree>
                                        <field name="display_name"/>
                                        <field name="list_price"/>
                                        <field name="category_id"/>
                                    </tree>
                                </field>
                            </page>
                            <page name="categories" string="Categories">
                                <field name="category_ids">
                                    <tree>
                                        <field name="display_name"/>
                                        <field name="sequence"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_self_order_menu" model="ir.actions.act_window">
            <field name="name">Self Order Menus</field>
            <field name="res_model">odfe.self.order.menu</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_self_order_menus" name="Menus"
            parent="menu_self_order_root" action="action_self_order_menu" sequence="15"/>

    </data>
</odoo>
