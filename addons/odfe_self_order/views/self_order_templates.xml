<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="self_order_page" name="Self Order Page">
            <t t-call="web.html_container">
                <t t-set="body_class" value="self_order_body"/>
                <t t-call="odfe_self_order.self_order_layout"/>
            </t>
        </template>

        <template id="self_order_layout" name="Self Order Layout">
            <div class="self-order-container">
                <div class="self-order-header">
                    <h1><t t-esc="restaurant_name or 'Menu'"/></h1>
                    <span class="table-badge">Table <t t-esc="table_name"/></span>
                </div>
                <style>
                        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
                        html,body{height:100%;overflow:hidden}
                        .self_order_body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f8f9fa;color:#1a1a2e;-webkit-font-smoothing:antialiased}
                        #self_order_app{height:100vh;display:flex;flex-direction:column;max-width:480px;margin:0 auto;position:relative;background:#f8f9fa}
                        .loading-screen{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:16px}
                        .loading-spinner{width:48px;height:48px;border:4px solid #e9ecef;border-top-color:#e74c3c;border-radius:50%;animation:spin .8s linear infinite}
                        @keyframes spin{to{transform:rotate(360deg)}}
                        .loading-text{color:#6c757d;font-size:15px;font-weight:500}
                        .error-screen{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;padding:32px;text-align:center;gap:16px}
                        .error-icon{width:64px;height:64px;background:#e74c3c;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:700}
                        .error-screen h2{font-size:18px;font-weight:600;color:#1a1a2e}
                        .btn-primary{padding:12px 32px;background:#e74c3c;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:600;cursor:pointer;transition:.3s ease;font-family:'Inter',sans-serif}
                        .btn-primary:hover{background:#c0392b;transform:translateY(-1px);box-shadow:0 4px 12px rgba(0,0,0,.1)}
                        .app-header{background:#fff;padding:16px;padding-top:max(16px,env(safe-area-inset-top));border-bottom:1px solid #e9ecef;position:sticky;top:0;z-index:100;flex-shrink:0}
                        .header-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
                        .table-badge{background:#2c3e50;color:#fff;padding:6px 16px;border-radius:20px;font-size:13px;font-weight:600;letter-spacing:.3px}
                        .cart-button{position:relative;background:0 0;border:2px solid #e9ecef;border-radius:50%;width:44px;height:44px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.3s ease}
                        .cart-button:hover{border-color:#e74c3c}
                        .cart-button.has-items{border-color:#e74c3c;background:rgba(231,76,60,.05)}
                        .cart-icon{font-size:20px}
                        .cart-count{position:absolute;top:-6px;right:-6px;background:#e74c3c;color:#fff;width:22px;height:22px;border-radius:50%;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 3px rgba(0,0,0,.08)}
                        .header-search{margin-bottom:12px}
                        .search-input{width:100%;padding:10px 16px;border:2px solid #e9ecef;border-radius:12px;font-size:14px;font-family:'Inter',sans-serif;outline:0;transition:.3s ease;background:#f8f9fa}
                        .search-input:focus{border-color:#e74c3c;background:#fff;box-shadow:0 0 0 3px rgba(231,76,60,.1)}
                        .search-input::placeholder{color:#6c757d}
                        .category-tabs{display:flex;overflow-x:auto;gap:8px;padding-bottom:4px;scrollbar-width:none}
                        .category-tabs::-webkit-scrollbar{display:none}
                        .category-tab{flex-shrink:0;padding:8px 18px;border:2px solid #e9ecef;border-radius:20px;background:#fff;color:#6c757d;font-size:13px;font-weight:600;cursor:pointer;transition:.3s ease;font-family:'Inter',sans-serif;white-space:nowrap}
                        .category-tab:hover{border-color:#e74c3c;color:#e74c3c}
                        .category-tab.active{background:#2c3e50;border-color:#2c3e50;color:#fff}
                        .menu-content{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:16px;padding-bottom:24px}
                        .category-section{margin-bottom:24px}
                        .category-header{margin-bottom:12px;border-radius:12px;overflow:hidden}
                        .category-header img{width:100%;height:140px;object-fit:cover;border-radius:12px}
                        .category-title{font-size:20px;font-weight:700;color:#1a1a2e;margin-bottom:12px;letter-spacing:-.3px}
                        .product-grid{display:flex;flex-direction:column;gap:12px}
                        .product-card{display:flex;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.08);transition:.3s ease;cursor:pointer}
                        .product-card:hover{box-shadow:0 4px 12px rgba(0,0,0,.1);transform:translateY(-2px)}
                        .product-image{width:110px;min-height:110px;flex-shrink:0;overflow:hidden}
                        .product-image img{width:100%;height:100%;object-fit:cover}
                        .product-info{flex:1;padding:12px 14px;display:flex;flex-direction:column;justify-content:space-between}
                        .product-name{font-size:15px;font-weight:600;color:#1a1a2e;margin-bottom:4px;line-height:1.3}
                        .product-desc{font-size:12px;color:#6c757d;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:8px}
                        .product-bottom{display:flex;justify-content:space-between;align-items:center;margin-top:auto}
                        .product-price{font-size:17px;font-weight:700;color:#2c3e50}
                        .btn-add{padding:7px 18px;background:#e74c3c;color:#fff;border:none;border-radius:20px;font-size:13px;font-weight:600;cursor:pointer;transition:.3s ease;font-family:'Inter',sans-serif}
                        .btn-add:hover{background:#c0392b;transform:scale(1.05)}
                        .cart-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;opacity:0;pointer-events:none;transition:opacity .3s ease}
                        .cart-overlay.open{opacity:1;pointer-events:auto}
                        .cart-panel{position:fixed;top:0;right:0;bottom:0;width:100%;max-width:400px;background:#fff;z-index:300;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);box-shadow:0 16px 48px rgba(0,0,0,.15)}
                        .cart-panel.open{transform:translateX(0)}
                        .cart-header{display:flex;justify-content:space-between;align-items:center;padding:20px;padding-top:max(20px,env(safe-area-inset-top));border-bottom:1px solid #e9ecef}
                        .cart-header h2{font-size:20px;font-weight:700}
                        .cart-close{background:0 0;border:none;font-size:22px;cursor:pointer;color:#6c757d;padding:4px;transition:.3s ease}
                        .cart-close:hover{color:#1a1a2e}
                        .cart-items{flex:1;overflow-y:auto;padding:16px 20px}
                        .cart-item{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid #e9ecef}
                        .cart-item-info{display:flex;flex-direction:column;gap:8px}
                        .cart-item-name{font-size:14px;font-weight:600}
                        .cart-item-controls{display:flex;align-items:center;gap:8px}
                        .qty-btn{width:32px;height:32px;border-radius:50%;border:2px solid #e9ecef;background:#fff;font-size:16px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.3s ease;color:#1a1a2e;font-family:'Inter',sans-serif}
                        .qty-btn:hover{border-color:#e74c3c;color:#e74c3c}
                        .qty-value{font-size:15px;font-weight:600;min-width:24px;text-align:center}
                        .cart-item-total{display:flex;flex-direction:column;align-items:flex-end;gap:4px;font-size:15px;font-weight:700}
                        .cart-item-remove{background:0 0;border:none;color:#6c757d;font-size:12px;cursor:pointer;padding:2px;transition:.3s ease}
                        .cart-item-remove:hover{color:#e74c3c}
                        .cart-footer{padding:16px 20px;padding-bottom:max(16px,env(safe-area-inset-bottom));border-top:1px solid #e9ecef;background:#fff}
                        .cart-totals{margin-bottom:12px}
                        .cart-total-row{display:flex;justify-content:space-between;font-size:14px;color:#6c757d;margin-bottom:4px}
                        .cart-total-row.total{font-size:18px;font-weight:700;color:#1a1a2e;margin-top:8px;padding-top:8px;border-top:1px solid #e9ecef}
                        .cart-note{margin-bottom:12px}
                        .note-input{width:100%;padding:10px 14px;border:2px solid #e9ecef;border-radius:8px;font-size:13px;font-family:'Inter',sans-serif;outline:0;transition:.3s ease}
                        .note-input:focus{border-color:#e74c3c}
                        .btn-checkout{width:100%;padding:14px;background:#2c3e50;color:#fff;border:none;border-radius:12px;font-size:16px;font-weight:700;cursor:pointer;transition:.3s ease;font-family:'Inter',sans-serif}
                        .btn-checkout:hover{background:#1a252f;box-shadow:0 4px 12px rgba(0,0,0,.1);transform:translateY(-1px)}
                        .checkout-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:400}
                        .checkout-modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);width:90%;max-width:420px;max-height:85vh;overflow-y:auto;background:#fff;border-radius:20px;z-index:500;padding:24px;box-shadow:0 16px 48px rgba(0,0,0,.15);animation:modalIn .3s ease}
                        @keyframes modalIn{from{opacity:0;transform:translate(-50%,-50%) scale(.9)}to{opacity:1;transform:translate(-50%,-50%) scale(1)}}
                        .checkout-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
                        .checkout-header h2{font-size:22px;font-weight:700}
                        .checkout-close{background:0 0;border:none;font-size:22px;cursor:pointer;color:#6c757d;transition:.3s ease}
                        .checkout-close:hover{color:#1a1a2e}
                        .checkout-items{margin-bottom:16px}
                        .checkout-item{display:flex;justify-content:space-between;padding:8px 0;font-size:14px}
                        .checkout-item-name{font-weight:500}
                        .checkout-item-price{font-weight:600}
                        .checkout-totals{margin-bottom:16px;padding-top:12px;border-top:2px solid #e9ecef}
                        .checkout-total-row{display:flex;justify-content:space-between;font-size:14px;color:#6c757d;margin-bottom:4px}
                        .checkout-total-row.total{font-size:20px;font-weight:700;color:#1a1a2e;margin-top:8px;padding-top:8px;border-top:1px solid #e9ecef}
                        .checkout-contact{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
                        .contact-input{width:100%;padding:12px 14px;border:2px solid #e9ecef;border-radius:8px;font-size:14px;font-family:'Inter',sans-serif;outline:0;transition:.3s ease}
                        .contact-input:focus{border-color:#e74c3c}
                        .btn-place-order{width:100%;padding:16px;background:#e74c3c;color:#fff;border:none;border-radius:12px;font-size:17px;font-weight:700;cursor:pointer;transition:.3s ease;font-family:'Inter',sans-serif}
                        .btn-place-order:hover:not(:disabled){background:#c0392b;box-shadow:0 4px 12px rgba(0,0,0,.1);transform:translateY(-1px)}
                        .btn-place-order:disabled{opacity:.7;cursor:not-allowed}
                        .success-screen{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;padding:32px;text-align:center;gap:12px;animation:fadeIn .5s ease}
                        @keyframes fadeIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
                        .success-icon{width:80px;height:80px;background:#27ae60;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:36px;font-weight:700;margin-bottom:8px;box-shadow:0 4px 20px rgba(39,174,96,.3)}
                        .success-screen h2{font-size:24px;font-weight:700;color:#1a1a2e}
                        .success-ref{font-size:16px;font-weight:600;color:#e74c3c}
                        .success-msg{font-size:14px;color:#6c757d;margin-bottom:12px}
                        @media(min-width:480px){#self_order_app{border-left:1px solid #e9ecef;border-right:1px solid #e9ecef;box-shadow:0 8px 24px rgba(0,0,0,.12)}}
                        @media(max-width:380px){.product-image{width:80px;min-height:80px}.product-name{font-size:13px}.product-price{font-size:15px}.btn-add{padding:6px 14px;font-size:12px}}
                    </style>
                    <div id="self_order_app" t-att-data-qr-token="qr_token" t-att-data-table-id="table_id" t-att-data-table-name="table_name">
                        <div class="loading-screen">
                            <div class="loading-spinner"></div>
                            <p class="loading-text">Loading menu...</p>
                        </div>
                    </div>
                </div>
        </template>

    </data>
</odoo>
