meta {
  name: Customer Token
  type: item
  description: Generate customer JWT from table token (QR code)
}

request {
  method: POST
  url: {{base_url}}/api/auth/customer-token
  header Content-Type: application/json
  body:json {
    "tableToken": "table-token-abc-123"
  }
}

script:post-response {
  const data = res.getBody();
  if (res.status === 200) {
    bru.setVar("customer_token", data.data.accessToken);
  }
}
